---
import type { Page, PagePath, ArticlePost } from "../../types";
import { PostCollections, getArticleSortFn } from "../../shared/postsCache";
import { pageSize } from "../../shared/pagination";
import {
  HOME_ARTICLE_LIST_CTA_INTERVALS,
  HOME_ARTICLE_LIST_CTA_LIMIT,
  getArticleListCtaOccurrence,
} from "../../shared/articleListCta";
import { ArticleCard } from "../../components/ArticleCard";
import ArticleListSkeleton from "../../components/ArticleListSkeleton.astro";
import ArticleListConsultingCTA from "../../components/ArticleListConsultingCTA.astro";
import { PaginateFunction } from "astro";
import { DEFAULT_LOCALE, type Locale } from "../../shared/i18n";
// import { RefreshCw } from "lucide-react";

export const partial = true;

type Props = {
  page: Page<ArticlePost>;
  pageUrlSuffix: string;
  sortKey: string;
  field: string;
  direction: "asc" | "desc";
  locale?: Locale;
};

export async function getStaticPaths({
  paginate,
}: {
  paginate: PaginateFunction;
}) {
  const sortKeys = [
    ["date", "asc"],
    ["date", "desc"],
    ["modified", "asc"],
    ["modified", "desc"],
  ] as const;

  const pages = sortKeys.flatMap(([field, direction]) => {
    const posts = (PostCollections.getPostsForLocale(DEFAULT_LOCALE) as ArticlePost[]).filter(
      (post) => !post.data.unlisted,
    );
    const sortFn = getArticleSortFn(field, direction);
    const sortedPosts = posts.concat().sort(sortFn);

    const pageData = paginate(PostCollections.getStaticPaths(sortedPosts), {
      pageSize,
    });
    // console.warn("📄 PAGE DATA", pageData)

    const fixed = pageData.flatMap((p: any) => ({
      ...p,
      props: {
        ...p.props,
        // page: `${field}-${direction}`,
        sortKey: `${field}-${direction}`,
        pageUrlSuffix: `-${field}${direction === "asc" ? "" : "-desc"}.html`,
        field,
        direction,
      },
      params: {
        ...p.params,
        pageUrlSuffix: `-${field}${direction === "asc" ? "" : "-desc"}.html`,
        page: `${p.params.page ?? "1"}-${field}${direction === "asc" ? "" : "-desc"}`,
        sortKey: `${field}-${direction}`,
        field,
        direction,
      },
    }));

    // console.warn("📄 FIXED", fixed);
    return fixed;
  });
  // console.warn("📄 PAGES", pages);
  return pages as PagePath[];
}

const {
  page: { data, currentPage, lastPage, url },
  pageUrlSuffix,
} = Astro.props;
const locale = (Astro.props.locale ?? DEFAULT_LOCALE) as Locale;
// console.log("📄 PROPS", Astro.props);
// console.log("📄 NEXT", `${url.next ? url.next + pageUrlSuffix :url.next}`);

// , currentPage, start, end, size, lastPage, total, url
// console.log("📄 Page", data);
let nextUrl: string | null = null;
// const head = (arr: any[], n: number) => arr.slice(0, n);

const isLast = currentPage === lastPage;
if (!isLast) {
  // const dirSuffix = direction === "asc" ? "" : "-desc";
  nextUrl = `${url.next ? url.next + pageUrlSuffix : url.next}`;
  // prevUrl = `${url.prev ? url.prev + pageUrlSuffix : url.prev}`;
}

const articleListOffset = (currentPage - 1) * (pageSize - 1);

---

{
  data.map(({ props }: any, index) => {
    const ctaOccurrence = getArticleListCtaOccurrence(
      index,
      articleListOffset,
      HOME_ARTICLE_LIST_CTA_LIMIT,
      HOME_ARTICLE_LIST_CTA_INTERVALS,
    );

    return (
    <>
      <ArticleCard article={props as ArticlePost} width={200} locale={locale} />
      {ctaOccurrence !== null && (
        <ArticleListConsultingCTA
          category={ctaOccurrence === 1 ? undefined : (props as ArticlePost).data.category}
          compact
          pageCount={ctaOccurrence}
          singleColumn
        />
      )}
    </>
    );
  })
}

<ArticleListSkeleton nextUrl={nextUrl} />
