---
import ConsultingServicePage from "./_ConsultingServicePage.astro";
import {
  consultingServices,
  consultingServicesBySlug,
} from "../../data/consultingServices";
import { DEFAULT_LOCALE } from "../../shared/i18n";

export function getStaticPaths() {
  return consultingServices.map((service) => ({
    params: { service: service.slug },
    props: { service, locale: DEFAULT_LOCALE },
  }));
}

const service =
  Astro.props.service ?? consultingServicesBySlug.get(Astro.params.service ?? "");

if (!service) {
  throw new Error(`Unknown consulting service: ${Astro.params.service}`);
}
---

<ConsultingServicePage service={service} locale={Astro.props.locale ?? DEFAULT_LOCALE} />
