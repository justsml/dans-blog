---
import Layout from "../layouts/Page.astro";
import {
  INTRO_CALL_LINK,
  consultingServices,
} from "../data/consultingServices";
import type { ConsultingService } from "../data/consultingServices";

const title = "Senior Software Architecture & Security Consulting";
const description =
  "Independent consulting for AI systems, security reviews, RAG rescue, Supabase scaling, developer workflow hardening, and expensive architecture decisions.";

const featuredSlugs = ["ai-consulting", "ai-guardrails"];
const featuredServices = featuredSlugs
  .map((slug) => consultingServices.find((service) => service.slug === slug))
  .filter((service): service is ConsultingService => Boolean(service));
const supportingServices = consultingServices.filter(
  (service) => !featuredSlugs.includes(service.slug),
);

const serviceVisuals: Record<string, { accent: string; mark: string; image: string }> = {
  "ai-consulting": {
    accent: "cyan",
    mark: "AI",
    image: "/images/consulting/service-ai-consulting.webp",
  },
  "ai-guardrails": {
    accent: "coral",
    mark: "GR",
    image: "/images/consulting/service-ai-guardrails.webp",
  },
  "supabase-scaling-migration": {
    accent: "amber",
    mark: "SB",
    image: "/images/consulting/service-supabase.webp",
  },
  "rag-rescue": {
    accent: "cyan",
    mark: "RG",
    image: "/images/consulting/service-rag.webp",
  },
  "developer-ai-coding-security": {
    accent: "coral",
    mark: "CS",
    image: "/images/consulting/service-coding-security.webp",
  },
  "enterprise-security-assessment": {
    accent: "amber",
    mark: "ES",
    image: "/images/consulting/service-enterprise-security.webp",
  },
};

const processSteps = [
  {
    title: "Diagnose",
    body: "Start with architecture, traces, bills, incidents, and workflow friction.",
  },
  {
    title: "Map tradeoffs",
    body: "Separate high-leverage fixes from distractions and make cost, risk, quality, and effort visible.",
  },
  {
    title: "Ship changes",
    body: "Stay close to implementation so your team leaves with working changes, not just advice.",
  },
  {
    title: "Measure",
    body: "Compare against the baseline and leave observability notes your team can keep using.",
  },
];

const serviceSummaries: Record<string, string> = {
  "ai-consulting":
    "Clarify AI architecture, model routing, token cost, observability, and production tradeoffs.",
  "ai-guardrails":
    "Add practical safety controls, policy checks, and review paths without slowing the product team.",
  "supabase-scaling-migration":
    "Reduce hosted-platform cost and migration risk before growth makes the stack harder to move.",
  "rag-rescue":
    "Diagnose retrieval drift, weak grounding, and document-scale failures in production RAG systems.",
  "developer-ai-coding-security":
    "Harden AI-assisted coding workflows, sandboxes, repository access, credentials, and CI/CD.",
  "enterprise-security-assessment":
    "Review application, cloud, identity, workflow, AI exposure, and organizational security risk.",
};

const trustSignals = [
  {
    value: "$22.5K/mo",
    label: "auth spend removed before a major growth push",
  },
  {
    value: "14x",
    label: "user growth absorbed after the migration",
  },
  {
    value: "25-50K",
    label: "documents where retrieval quality started to fail",
  },
  {
    value: "Senior-only",
    label: "you work directly with the person doing the work",
  },
];

const proofPoints = [
  "Reviews grounded in code, traces, invoices, and incidents",
  "Implementation support for the fixes that matter most",
  "Clear tradeoff notes for engineering and leadership",
];

const caseProofs = consultingServices
  .filter((service) => service.caseStudy)
  .map((service) => ({
    service: service.navTitle,
    ...service.caseStudy!,
  }));

const fitSignals = [
  "A production AI feature is getting expensive or hard to explain",
  "A launch, migration, audit, or growth event has raised the risk",
  "You need senior judgment without adding a full-time seat",
];
---

<Layout frontmatter={{ title, subTitle: description }}>
  <section class="consulting-hero full-section">
    <div class="consulting-shell consulting-practice-bar">
      <a class="practice-home" href="/">
        <span class="practice-mark">DL</span>
        <span>
          <strong>DanLevy.net</strong>
          <small>Return to the writing</small>
        </span>
      </a>
      <div class="practice-divider" aria-hidden="true"></div>
      <span class="practice-label">Consulting practice</span>
    </div>

    <div class="consulting-shell hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Independent senior consulting</p>
        <h1>Senior engineering judgment for critical systems.</h1>
        <p class="hero-sub">
          I help teams make high-stakes architecture decisions in AI, security,
          retrieval, platform migration, and developer workflow.
        </p>
        <div class="hero-actions">
          <a href={INTRO_CALL_LINK} class="btn btn-primary" target="_blank" rel="noopener">
            <span>Book diagnostic call</span>
            <span class="btn-icon" aria-hidden="true">↗</span>
          </a>
          <a href="#services" class="btn btn-secondary">See services</a>
        </div>
        <ul class="hero-proof" aria-label="Engagement proof">
          {proofPoints.map((point) => <li>{point}</li>)}
        </ul>
      </div>

      <div class="hero-visual-stack">
        <div class="hero-art" aria-hidden="true">
          <img
            src="/images/consulting/consulting-hero-workbench.webp"
            alt=""
            loading="eager"
            decoding="async"
          />
        </div>
        <div class="hero-insight-card">
          <span>Common starting point</span>
          <strong>"We shipped quickly. Now the system is expensive to reason about."</strong>
        </div>
      </div>
    </div>
  </section>

  <section class="trust-section full-section" aria-labelledby="trust-heading">
    <div class="consulting-shell trust-grid">
      <div>
        <p class="eyebrow">Trust model</p>
        <h2 id="trust-heading">Make the system legible before changing it.</h2>
      </div>
      <div class="trust-copy">
        <p>
          The work starts with the facts your team already has: traces, bills,
          incidents, prompts, schemas, CI behavior, and failure cases. From
          there, the tradeoffs become visible enough to act on.
        </p>
      </div>
    </div>
    <div class="consulting-shell trust-metrics" aria-label="Consulting proof points">
      {trustSignals.map((signal) => (
        <article class="trust-metric">
          <strong>{signal.value}</strong>
          <span>{signal.label}</span>
        </article>
      ))}
    </div>
  </section>

  <section id="services" class="consulting-section full-section">
    <div class="consulting-shell">
      <div class="section-heading">
        <p class="eyebrow">Services</p>
        <h2>Focused consulting for expensive technical decisions.</h2>
        <p>
          Senior help when the cost, risk, or architecture has become too
          important to handle with guesses.
        </p>
      </div>

      <div class="featured-services">
        {featuredServices.map((service) => {
          const visual = serviceVisuals[service.slug];
          return (
            <a class={`featured-card ${visual.accent}`} href={`/consulting/${service.slug}/`}>
              <div class="card-image" aria-hidden="true">
                <img src={visual.image} alt="" loading="eager" decoding="async" />
              </div>
              <div class="service-mark">{visual.mark}</div>
              <p class="card-kicker">{service.kicker}</p>
              <h3>{service.navTitle}</h3>
              <p>{serviceSummaries[service.slug] ?? service.description}</p>
              <span class="card-link">Explore service <span aria-hidden="true">→</span></span>
            </a>
          );
        })}
      </div>

      <div class="service-grid">
        {supportingServices.map((service) => {
          const visual = serviceVisuals[service.slug] ?? {
            accent: "cyan",
            mark: service.navTitle.slice(0, 2).toUpperCase(),
            image: "/images/consulting/service-ai-consulting.webp",
          };
          return (
            <a class={`service-card ${visual.accent}`} href={`/consulting/${service.slug}/`}>
              <div class="supporting-image" aria-hidden="true">
                <img src={visual.image} alt="" loading="eager" decoding="async" />
              </div>
              <div class="service-mark">{visual.mark}</div>
              <p class="card-kicker">{service.kicker}</p>
              <h3>{service.navTitle}</h3>
              <p>{serviceSummaries[service.slug] ?? service.description}</p>
              <span class="card-link">Explore service <span aria-hidden="true">→</span></span>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <section class="consulting-section proof-section full-section">
    <div class="consulting-shell proof-grid">
      <div class="section-heading sticky-heading">
        <p class="eyebrow">Evidence</p>
        <h2>Concrete problems. Measurable outcomes.</h2>
        <p>
          The best engagements start with a live system, a real constraint, and
          a decision that has become expensive to delay.
        </p>
      </div>
      <div class="case-stack">
        {caseProofs.map((item) => (
          <article class="case-card">
            <p class="card-kicker">{item.label} · {item.service}</p>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
            <strong>{item.highlight}</strong>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="consulting-section process-section full-section">
    <div class="consulting-shell process-grid">
      <div>
        <p class="eyebrow">How I work</p>
        <h2>From diagnosis to shipped change.</h2>
        <p class="section-copy">
          I work best when the problem is already real: a costly bill, a risky
          launch, a failing retrieval system, or a security surface growing
          faster than the controls around it.
        </p>
        <a href={INTRO_CALL_LINK} class="btn btn-primary" target="_blank" rel="noopener">
          <span>Start diagnostic call</span>
          <span class="btn-icon" aria-hidden="true">↗</span>
        </a>
      </div>

      <div class="process-panel">
        <img
          src="/images/consulting/service-rag.webp"
          alt=""
          loading="eager"
          decoding="async"
          aria-hidden="true"
        />
        <div class="steps">
          {processSteps.map((step, index) => (
            <article class="step">
              <span>0{index + 1}</span>
              <div>
                <h3>{step.title}</h3>
                <p>{step.body}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section id="about" class="consulting-section about-section full-section">
    <div class="consulting-shell about-grid">
      <div class="about-card">
        <div class="about-avatar">DL</div>
        <div>
          <p class="eyebrow">Dan Levy</p>
          <h2>Work directly with Dan Levy.</h2>
          <p>
            I work with a small number of companies each year. The useful part
            is senior judgment near the implementation: reviewing architecture,
            talking with engineers, shaping the plan, and helping ship the
            changes.
          </p>
        </div>
      </div>

      <div class="capability-strip">
        <span>AI systems</span>
        <span>Guardrails</span>
        <span>RAG</span>
        <span>Supabase</span>
        <span>Security</span>
      </div>
    </div>
    <div class="consulting-shell fit-panel">
      <p class="eyebrow">Good fit</p>
      <div class="fit-list">
        {fitSignals.map((signal) => <p>{signal}</p>)}
      </div>
    </div>
  </section>

  <section class="consulting-cta full-section">
    <div class="consulting-shell cta-grid">
      <div>
        <p class="eyebrow">Next step</p>
        <h2>Bring the problem that keeps coming back.</h2>
        <p>
          Bring the bill, launch risk, retrieval failure, security concern, or
          platform decision your team keeps circling. We will identify the next
          useful move quickly.
        </p>
        <div class="hero-actions">
          <a href={INTRO_CALL_LINK} class="btn btn-primary" target="_blank" rel="noopener">
            <span>Book diagnostic call</span>
            <span class="btn-icon" aria-hidden="true">↗</span>
          </a>
          <a href="/" class="btn btn-secondary">Read the writing</a>
        </div>
      </div>
      <div class="cta-art" aria-hidden="true">
        <img
          src="/images/consulting/service-enterprise-security.webp"
          alt=""
          loading="eager"
          decoding="async"
        />
      </div>
    </div>
  </section>
</Layout>

<style>
  :root {
    --consulting-bg: #05080b;
    --consulting-ink: #f4f0e8;
    --consulting-muted: rgba(244, 240, 232, 0.72);
    --consulting-soft: rgba(244, 240, 232, 0.54);
    --consulting-line: rgba(244, 240, 232, 0.11);
    --consulting-panel: rgba(244, 240, 232, 0.045);
    --consulting-panel-strong: rgba(244, 240, 232, 0.075);
    --consulting-cyan: #28e8df;
    --consulting-coral: #ff73c9;
    --consulting-amber: #d8a84b;
    --consulting-radius: 18px;
    --consulting-radius-sm: 10px;
    --consulting-shadow: 0 28px 90px rgba(0, 18, 28, 0.58);
    --consulting-motion: 520ms cubic-bezier(0.32, 0.72, 0, 1);
    --consulting-font: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "SF Pro Text", "Segoe UI", sans-serif;
  }

  .full-section {
    grid-column: full-width;
    width: 100%;
  }

  .consulting-hero,
  .consulting-section,
  .consulting-cta,
  .trust-section {
    background:
      linear-gradient(rgba(244, 240, 232, 0.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(244, 240, 232, 0.035) 1px, transparent 1px),
      radial-gradient(circle at 15% 12%, rgba(40, 232, 223, 0.14), transparent 30rem),
      radial-gradient(circle at 88% 18%, rgba(255, 115, 201, 0.1), transparent 26rem),
      var(--consulting-bg);
    background-size: 56px 56px, 56px 56px, auto, auto, auto;
    color: var(--consulting-ink);
  }

  .consulting-shell {
    width: min(1180px, calc(100% - 3rem));
    margin: 0 auto;
  }

  .consulting-hero {
    padding: clamp(4rem, 8vw, 7rem) 0 5rem;
    overflow: hidden;
  }

  .consulting-hero::after {
    background: linear-gradient(90deg, transparent, rgba(40, 232, 223, 0.75), rgba(255, 115, 201, 0.62), transparent);
    content: "";
    display: block;
    height: 1px;
    margin: clamp(4rem, 7vw, 6rem) auto 0;
    opacity: 0.58;
    width: min(1180px, calc(100% - 3rem));
  }

  .consulting-practice-bar {
    align-items: center;
    display: flex;
    gap: 1rem;
    justify-content: flex-start;
    margin-bottom: clamp(3rem, 6vw, 5.5rem);
  }

  .practice-home {
    align-items: center;
    background: rgba(244, 240, 232, 0.045);
    border: 1px solid var(--consulting-line);
    border-radius: 999px;
    color: var(--consulting-ink);
    display: inline-flex;
    gap: 0.85rem;
    padding: 0.55rem 1rem 0.55rem 0.55rem;
    text-decoration: none;
    transition: border-color var(--consulting-motion), background var(--consulting-motion), transform var(--consulting-motion);
  }

  .practice-home:hover {
    background: rgba(244, 240, 232, 0.07);
    border-color: rgba(37, 214, 196, 0.35);
    transform: translateY(-1px);
  }

  .practice-mark {
    align-items: center;
    background: linear-gradient(135deg, rgba(37, 214, 196, 0.2), rgba(255, 127, 103, 0.13));
    border: 1px solid rgba(244, 240, 232, 0.13);
    border-radius: 50%;
    display: flex;
    flex: 0 0 auto;
    font-size: 0.76rem;
    font-weight: 800;
    height: 2.25rem;
    justify-content: center;
    letter-spacing: 0.02em;
    width: 2.25rem;
  }

  .practice-home strong,
  .practice-home small {
    display: block;
    line-height: 1.1;
  }

  .practice-home strong {
    font-size: 0.9rem;
    letter-spacing: -0.01em;
  }

  .practice-home small {
    color: var(--consulting-soft);
    font-size: 0.72rem;
    font-weight: 650;
    margin-top: 0.18rem;
  }

  .practice-divider {
    background: linear-gradient(90deg, rgba(244, 240, 232, 0.28), transparent);
    height: 1px;
    max-width: 12rem;
    flex: 1 1 8rem;
  }

  .practice-label {
    color: var(--consulting-soft);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  .hero-grid,
  .process-grid,
  .about-grid,
  .cta-grid,
  .trust-grid,
  .proof-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
  }

  .eyebrow,
  .card-kicker {
    color: var(--consulting-cyan);
    font-family: var(--consulting-font);
    font-size: 0.72rem;
    font-weight: 650;
    letter-spacing: 0.08em;
    line-height: 1.2;
    margin: 0 0 1.15rem;
    text-transform: uppercase;
  }

  .eyebrow {
    color: rgba(40, 232, 223, 0.88);
  }

  h1,
  h2,
  h3,
  p,
  a,
  span,
  strong,
  li {
    font-family: var(--consulting-font);
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
    text-shadow: none !important;
  }

  h1 {
    max-width: 720px;
    color: var(--consulting-ink);
    font-size: clamp(3.25rem, 6.1vw, 5.65rem);
    font-weight: 590;
    letter-spacing: -0.058em;
    line-height: 0.95;
    margin-bottom: 1.55rem;
    text-wrap: balance;
  }

  h2 {
    color: var(--consulting-ink);
    font-size: clamp(2.45rem, 4.8vw, 4.8rem);
    font-weight: 620;
    letter-spacing: -0.058em;
    line-height: 0.98;
    margin-bottom: 1.05rem;
    max-width: 13ch;
    text-wrap: balance;
  }

  h3 {
    color: var(--consulting-ink);
    font-size: clamp(1.08rem, 1.35vw, 1.34rem);
    font-weight: 610;
    letter-spacing: -0.027em;
    line-height: 1.12;
    margin-bottom: 0.72rem;
    text-wrap: balance;
  }

  .hero-sub,
  .section-heading p,
  .section-copy,
  .consulting-cta p,
  .about-card p {
    color: var(--consulting-muted);
    font-size: clamp(1.02rem, 1.42vw, 1.16rem);
    font-weight: 420;
    line-height: 1.58;
    letter-spacing: -0.014em;
  }

  .hero-sub {
    max-width: 590px;
    margin-bottom: 2rem;
  }

  .hero-proof {
    display: grid;
    gap: 0.85rem;
    list-style: none;
    margin: 2rem 0 0;
    max-width: 620px;
    padding: 0;
  }

  .hero-proof li {
    color: rgba(244, 240, 232, 0.58);
    font-size: 0.88rem;
    font-weight: 430;
    line-height: 1.45;
    padding-left: 1.35rem;
    position: relative;
  }

  .hero-proof li::before {
    background: linear-gradient(135deg, var(--consulting-cyan), var(--consulting-coral));
    border-radius: 50%;
    box-shadow: 0 0 20px rgba(40, 232, 223, 0.28);
    content: "";
    height: 0.48rem;
    left: 0;
    position: absolute;
    top: 0.48rem;
    width: 0.48rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
  }

  .btn {
    align-items: center;
    border-radius: 999px;
    display: inline-flex;
    gap: 0.65rem;
    font-size: 0.96rem;
    font-weight: 620;
    justify-content: center;
    min-height: 3.25rem;
    padding: 0.72rem 0.82rem 0.72rem 1.35rem;
    text-decoration: none;
    transition: border-color var(--consulting-motion), box-shadow var(--consulting-motion), transform var(--consulting-motion), background var(--consulting-motion);
  }

  .btn-primary {
    background: var(--consulting-ink);
    box-shadow: 0 14px 45px rgba(40, 232, 223, 0.18);
    color: #050607;
  }

  .btn-icon {
    align-items: center;
    background: rgba(5, 6, 7, 0.09);
    border-radius: 50%;
    display: inline-flex;
    height: 2rem;
    justify-content: center;
    transition: transform var(--consulting-motion), background var(--consulting-motion);
    width: 2rem;
  }

  .btn-primary:hover,
  .btn-secondary:hover {
    transform: translateY(-2px);
  }

  .btn-primary:hover .btn-icon {
    background: rgba(5, 6, 7, 0.14);
    transform: translate(2px, -1px);
  }

  .btn:active {
    transform: translateY(0) scale(0.985);
  }

  .btn-secondary {
    background: rgba(244, 240, 232, 0.055);
    border: 1px solid var(--consulting-line);
    color: var(--consulting-ink);
    padding: 0.95rem 1.35rem;
  }

  .hero-visual-stack {
    position: relative;
  }

  .hero-art,
  .cta-art,
  .process-panel {
    border: 1px solid var(--consulting-line);
    border-radius: var(--consulting-radius);
    box-shadow: var(--consulting-shadow);
    overflow: hidden;
    position: relative;
  }

  .hero-art {
    aspect-ratio: 16 / 10;
    transform: rotate(1deg);
  }

  .hero-art::after,
  .cta-art::after,
  .card-image::after,
  .supporting-image::after {
    background: linear-gradient(135deg, rgba(40, 232, 223, 0.16), transparent 38%, rgba(255, 115, 201, 0.12));
    content: "";
    inset: 0;
    pointer-events: none;
    position: absolute;
  }

  .hero-insight-card {
    background:
      linear-gradient(135deg, rgba(244, 240, 232, 0.1), rgba(244, 240, 232, 0.045)),
      rgba(5, 8, 11, 0.94);
    border: 1px solid rgba(244, 240, 232, 0.14);
    border-radius: 14px;
    bottom: -1.5rem;
    box-shadow: 0 20px 70px rgba(0, 18, 28, 0.62);
    max-width: 20rem;
    padding: 1rem;
    position: absolute;
    right: 1.25rem;
  }

  .hero-insight-card span {
    color: var(--consulting-cyan);
    display: block;
    font-size: 0.7rem;
    font-weight: 680;
    letter-spacing: 0.08em;
    margin-bottom: 0.45rem;
    text-transform: uppercase;
  }

  .hero-insight-card strong {
    color: var(--consulting-ink);
    display: block;
    font-size: 0.98rem;
    font-weight: 560;
    letter-spacing: -0.018em;
    line-height: 1.34;
  }

  .hero-art img,
  .cta-art img,
  .process-panel > img,
  .card-image img,
  .supporting-image img {
    display: block;
    height: 100%;
    object-fit: cover;
    width: 100%;
  }

  .consulting-section,
  .trust-section {
    border-top: 1px solid var(--consulting-line);
    padding: clamp(4.5rem, 8vw, 7rem) 0;
  }

  .trust-section {
    background:
