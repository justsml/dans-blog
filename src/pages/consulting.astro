---
import Layout from "../layouts/Page.astro";
import {
  INTRO_CALL_LINK,
  consultingServices,
} from "../data/consultingServices";
import type { ConsultingService } from "../data/consultingServices";

const title = "Senior Software Architecture & Security Consulting";
const description =
  "Independent consulting for AI systems, security reviews, RAG rescue, Supabase scaling, developer workflow hardening, and expensive architecture decisions.";

const featuredSlugs = ["ai-consulting", "ai-guardrails"];
const featuredServices = featuredSlugs
  .map((slug) => consultingServices.find((service) => service.slug === slug))
  .filter((service): service is ConsultingService => Boolean(service));
const supportingServices = consultingServices.filter(
  (service) => !featuredSlugs.includes(service.slug),
);

const serviceVisuals: Record<string, { accent: string; mark: string; image: string }> = {
  "ai-consulting": {
    accent: "cyan",
    mark: "AI",
    image: "/images/consulting/service-ai-consulting.png",
  },
  "ai-guardrails": {
    accent: "coral",
    mark: "GR",
    image: "/images/consulting/service-ai-guardrails.png",
  },
  "supabase-scaling-migration": {
    accent: "amber",
    mark: "SB",
    image: "/images/consulting/service-supabase.png",
  },
  "rag-rescue": {
    accent: "cyan",
    mark: "RG",
    image: "/images/consulting/service-rag.png",
  },
  "developer-ai-coding-security": {
    accent: "coral",
    mark: "CS",
    image: "/images/consulting/service-coding-security.png",
  },
  "enterprise-security-assessment": {
    accent: "amber",
    mark: "ES",
    image: "/images/consulting/service-enterprise-security.png",
  },
};

const processSteps = [
  {
    title: "Diagnose",
    body: "We start with the real architecture, traces, bills, incidents, and workflow friction.",
  },
  {
    title: "Model the tradeoffs",
    body: "I separate high-leverage fixes from distractions and make cost, risk, quality, and effort visible.",
  },
  {
    title: "Ship the fix",
    body: "The engagement stays close to implementation so your team leaves with changes, not just advice.",
  },
  {
    title: "Measure what changed",
    body: "We compare against the baseline and leave behind the observability and handoff notes to keep improving.",
  },
];
---

<Layout frontmatter={{ title, subTitle: description }}>
  <section class="consulting-hero full-section">
    <div class="consulting-shell hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Independent senior consulting</p>
        <h1>Senior architecture for hard problems.</h1>
        <p class="hero-sub">
          AI systems, security reviews, retrieval rescue, platform migrations,
          and developer workflow hardening from one senior engineer.
        </p>
        <div class="hero-actions">
          <a href={INTRO_CALL_LINK} class="btn btn-primary" target="_blank" rel="noopener">
            Book a diagnostic call
          </a>
          <a href="#services" class="btn btn-secondary">View services</a>
        </div>
      </div>

      <div class="hero-art" aria-hidden="true">
        <img
          src="/images/consulting/consulting-hero.png"
          alt=""
          loading="eager"
          decoding="async"
        />
      </div>
    </div>
  </section>

  <section id="services" class="consulting-section full-section">
    <div class="consulting-shell">
      <div class="section-heading">
        <p class="eyebrow">Services</p>
        <h2>Services for hard engineering inflection points.</h2>
        <p>
          Focused senior help when the bill, the risk, or the architecture
          starts moving faster than the team can comfortably reason about.
        </p>
      </div>

      <div class="featured-services">
        {featuredServices.map((service) => {
          const visual = serviceVisuals[service.slug];
          return (
            <a class={`featured-card ${visual.accent}`} href={`/consulting/${service.slug}/`}>
              <div class="card-image" aria-hidden="true">
                <img src={visual.image} alt="" loading="lazy" decoding="async" />
              </div>
              <div class="service-mark">{visual.mark}</div>
              <p class="card-kicker">{service.kicker}</p>
              <h3>{service.navTitle}</h3>
              <p>{service.description}</p>
              <span>Explore service</span>
            </a>
          );
        })}
      </div>

      <div class="service-grid">
        {supportingServices.map((service) => {
          const visual = serviceVisuals[service.slug] ?? {
            accent: "cyan",
            mark: service.navTitle.slice(0, 2).toUpperCase(),
          image: "/images/consulting/service-ai-consulting.png",
          };
          return (
            <a class={`service-card ${visual.accent}`} href={`/consulting/${service.slug}/`}>
              <div class="supporting-image" aria-hidden="true">
                <img src={visual.image} alt="" loading="lazy" decoding="async" />
              </div>
              <div class="service-mark">{visual.mark}</div>
              <p class="card-kicker">{service.kicker}</p>
              <h3>{service.navTitle}</h3>
              <p>{service.description}</p>
              <span>Explore service</span>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <section class="consulting-section process-section full-section">
    <div class="consulting-shell process-grid">
      <div>
        <p class="eyebrow">How I work</p>
        <h2>From diagnosis to shipped leverage.</h2>
        <p class="section-copy">
          I work best when the problem is already real: a bill with teeth, a
          launch with risk, a retrieval system wobbling, or a security surface
          growing faster than the controls around it.
        </p>
        <a href={INTRO_CALL_LINK} class="btn btn-primary" target="_blank" rel="noopener">
          Start with a diagnostic call
        </a>
      </div>

      <div class="process-panel">
        <img
          src="/images/consulting/service-rag.png"
          alt=""
          loading="lazy"
          decoding="async"
          aria-hidden="true"
        />
        <div class="steps">
          {processSteps.map((step, index) => (
            <article class="step">
              <span>0{index + 1}</span>
              <div>
                <h3>{step.title}</h3>
                <p>{step.body}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section id="about" class="consulting-section about-section full-section">
    <div class="consulting-shell about-grid">
      <div class="about-card">
        <div class="about-avatar">DL</div>
        <div>
          <p class="eyebrow">Dan Levy</p>
          <h2>You get the person doing the work.</h2>
          <p>
            I am a software engineer and architect who works directly with a
            small number of companies each year. The useful bit is senior
            judgment close to the code: reviewing architecture, talking with
            engineers, shaping the plan, and helping the team ship the changes.
          </p>
        </div>
      </div>

      <div class="capability-strip">
        <span>AI systems</span>
        <span>Guardrails</span>
        <span>RAG</span>
        <span>Supabase</span>
        <span>Security</span>
      </div>
    </div>
  </section>

  <section class="consulting-cta full-section">
    <div class="consulting-shell cta-grid">
      <div>
        <p class="eyebrow">Next step</p>
        <h2>Bring the hard problem.</h2>
        <p>
          Bring the confusing bill, the brittle launch, the retrieval failure,
          the security concern, or the platform decision your team keeps
          circling. We will find the useful next move fast.
        </p>
        <div class="hero-actions">
          <a href={INTRO_CALL_LINK} class="btn btn-primary" target="_blank" rel="noopener">
            Book a diagnostic call
          </a>
          <a href="/" class="btn btn-secondary">Read the writing</a>
        </div>
      </div>
      <div class="cta-art" aria-hidden="true">
        <img
          src="/images/consulting/service-enterprise-security.png"
          alt=""
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </section>
</Layout>

<style>
  :root {
    --consulting-bg: #050607;
    --consulting-ink: #f4f0e8;
    --consulting-muted: rgba(244, 240, 232, 0.7);
    --consulting-soft: rgba(244, 240, 232, 0.48);
    --consulting-line: rgba(244, 240, 232, 0.11);
    --consulting-panel: rgba(244, 240, 232, 0.045);
    --consulting-panel-strong: rgba(244, 240, 232, 0.075);
    --consulting-cyan: #25d6c4;
    --consulting-coral: #ff7f67;
    --consulting-amber: #d8a84b;
    --consulting-radius: 18px;
    --consulting-radius-sm: 10px;
    --consulting-shadow: 0 28px 90px rgba(0, 0, 0, 0.5);
  }

  .full-section {
    grid-column: full-width;
    width: 100%;
  }

  .consulting-hero,
  .consulting-section,
  .consulting-cta {
    background:
      linear-gradient(rgba(244, 240, 232, 0.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(244, 240, 232, 0.035) 1px, transparent 1px),
      radial-gradient(circle at 15% 12%, rgba(37, 214, 196, 0.13), transparent 30rem),
      radial-gradient(circle at 88% 18%, rgba(255, 127, 103, 0.1), transparent 26rem),
      var(--consulting-bg);
    background-size: 56px 56px, 56px 56px, auto, auto, auto;
    color: var(--consulting-ink);
  }

  .consulting-shell {
    width: min(1180px, calc(100% - 3rem));
    margin: 0 auto;
  }

  .consulting-hero {
    padding: clamp(4rem, 8vw, 7rem) 0 5rem;
    overflow: hidden;
  }

  .hero-grid,
  .process-grid,
  .about-grid,
  .cta-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
  }

  .eyebrow,
  .card-kicker {
    color: var(--consulting-cyan);
    font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "SF Pro Text", "Helvetica Neue", Helvetica, Arial, sans-serif;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    margin: 0 0 1rem;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p,
  a,
  span {
    font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "SF Pro Text", "Helvetica Neue", Helvetica, Arial, sans-serif;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
    text-shadow: none !important;
  }

  h1 {
    max-width: 800px;
    color: var(--consulting-ink);
    font-size: clamp(3.1rem, 6.2vw, 5.6rem);
    font-weight: 760;
    letter-spacing: -0.055em;
    line-height: 0.94;
    margin-bottom: 1.4rem;
  }

  h2 {
    color: var(--consulting-ink);
    font-size: clamp(2.3rem, 4.7vw, 4.6rem);
    font-weight: 740;
    letter-spacing: -0.05em;
    line-height: 0.96;
    margin-bottom: 1rem;
  }

  h3 {
    color: var(--consulting-ink);
    font-size: clamp(1.18rem, 1.5vw, 1.42rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.08;
    margin-bottom: 0.7rem;
  }

  .hero-sub,
  .section-heading p,
  .section-copy,
  .consulting-cta p,
  .about-card p {
    color: var(--consulting-muted);
    font-size: clamp(1.04rem, 1.6vw, 1.25rem);
    line-height: 1.65;
    letter-spacing: -0.01em;
  }

  .hero-sub {
    max-width: 620px;
    margin-bottom: 2.2rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
  }

  .btn {
    align-items: center;
    border-radius: 999px;
    display: inline-flex;
    font-size: 0.96rem;
    font-weight: 700;
    justify-content: center;
    min-height: 3.25rem;
    padding: 0.95rem 1.35rem;
    text-decoration: none;
    transition: border-color 180ms ease, box-shadow 180ms ease, transform 180ms ease, background 180ms ease;
  }

  .btn-primary {
    background: var(--consulting-ink);
    box-shadow: 0 14px 45px rgba(37, 214, 196, 0.16);
    color: #050607;
  }

  .btn-primary:hover,
  .btn-secondary:hover {
    transform: translateY(-2px);
  }

  .btn-secondary {
    background: rgba(244, 240, 232, 0.055);
    border: 1px solid var(--consulting-line);
    color: var(--consulting-ink);
  }

  .hero-art,
  .cta-art,
  .process-panel {
    border: 1px solid var(--consulting-line);
    border-radius: var(--consulting-radius);
    box-shadow: var(--consulting-shadow);
    overflow: hidden;
    position: relative;
  }

  .hero-art {
    aspect-ratio: 1 / 0.82;
    transform: rotate(1deg);
  }

  .hero-art img,
  .cta-art img,
  .process-panel > img,
  .card-image img,
  .supporting-image img {
    display: block;
    height: 100%;
    object-fit: cover;
    width: 100%;
  }

  .consulting-section {
    border-top: 1px solid var(--consulting-line);
    padding: clamp(4.5rem, 8vw, 7rem) 0;
  }

  .section-heading {
    margin-bottom: clamp(2rem, 4vw, 3.25rem);
    max-width: 820px;
  }

  .section-heading p,
  .section-copy {
    max-width: 700px;
  }

  .featured-services {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-bottom: 1.25rem;
  }

  .featured-card,
  .service-card {
    background: linear-gradient(180deg, rgba(244, 240, 232, 0.075), rgba(244, 240, 232, 0.032));
    border: 1px solid var(--consulting-line);
    color: var(--consulting-muted);
    overflow: hidden;
    position: relative;
    text-decoration: none;
    transition: border-color 180ms ease, transform 180ms ease, background 180ms ease;
  }

  .featured-card:hover,
  .service-card:hover {
    background: linear-gradient(180deg, rgba(244, 240, 232, 0.1), rgba(244, 240, 232, 0.045));
    border-color: rgba(244, 240, 232, 0.22);
    transform: translateY(-3px);
  }

  .featured-card {
    border-radius: var(--consulting-radius);
    min-height: 490px;
    padding: 1.2rem 1.2rem 1.65rem;
  }

  .card-image {
    aspect-ratio: 16 / 9;
    border: 1px solid var(--consulting-line);
    border-radius: 14px;
    margin-bottom: 1.45rem;
    overflow: hidden;
  }

  .service-mark {
    align-items: center;
    background: rgba(244, 240, 232, 0.06);
    border: 1px solid var(--consulting-line);
    border-radius: 12px;
    color: var(--consulting-ink);
    display: inline-flex;
    font-size: 0.78rem;
    font-weight: 800;
    height: 2.7rem;
    justify-content: center;
    letter-spacing: 0.04em;
    margin-bottom: 1rem;
    width: 2.7rem;
  }

  .featured-card p,
  .service-card p {
    color: var(--consulting-muted);
    font-size: 0.95rem;
    line-height: 1.62;
    margin-bottom: 1.2rem;
  }

  .featured-card span,
  .service-card span {
    color: var(--consulting-ink);
    font-size: 0.9rem;
    font-weight: 750;
  }

  .featured-card.cyan .card-kicker,
  .service-card.cyan .card-kicker {
    color: var(--consulting-cyan);
  }

  .featured-card.coral .card-kicker,
  .service-card.coral .card-kicker {
    color: var(--consulting-coral);
  }

  .featured-card.amber .card-kicker,
  .service-card.amber .card-kicker {
    color: var(--consulting-amber);
  }

  .service-grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .service-card {
    border-radius: var(--consulting-radius-sm);
    min-height: 460px;
    padding: 1rem;
  }

  .supporting-image {
    aspect-ratio: 16 / 10;
    border: 1px solid var(--consulting-line);
    border-radius: 10px;
    filter: saturate(0.85);
    margin-bottom: 1.1rem;
    overflow: hidden;
    width: 100%;
  }

  .process-section {
    background:
      radial-gradient(circle at 18% 24%, rgba(216, 168, 75, 0.1), transparent 28rem),
      var(--consulting-bg);
  }

  .process-grid {
    align-items: start;
  }

  .process-panel {
    background: var(--consulting-panel);
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
  }

  .process-panel > img {
    min-height: 100%;
    opacity: 0.92;
  }

  .steps {
    display: grid;
    gap: 0;
  }

  .step {
    border-bottom: 1px solid var(--consulting-line);
    display: grid;
    gap: 1rem;
    grid-template-columns: 3rem minmax(0, 1fr);
    padding: 1.35rem;
  }

  .step:last-child {
    border-bottom: 0;
  }

  .step > span {
    color: var(--consulting-cyan);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
  }

  .step p {
    color: var(--consulting-muted);
    font-size: 0.9rem;
    line-height: 1.55;
    margin-bottom: 0;
  }

  .about-grid {
    grid-template-columns: minmax(0, 1fr) auto;
  }

  .about-card {
    align-items: start;
    display: grid;
    gap: 1.5rem;
    grid-template-columns: auto minmax(0, 1fr);
  }

  .about-avatar {
    align-items: center;
    background: linear-gradient(135deg, rgba(37, 214, 196, 0.16), rgba(255, 127, 103, 0.12));
    border: 1px solid var(--consulting-line);
    border-radius: 18px;
    color: var(--consulting-ink);
    display: flex;
    font-size: 2rem;
    font-weight: 800;
    height: 8rem;
    justify-content: center;
    width: 8rem;
  }

  .capability-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    justify-content: end;
    max-width: 340px;
  }

  .capability-strip span {
    background: rgba(244, 240, 232, 0.055);
    border: 1px solid var(--consulting-line);
    border-radius: 999px;
    color: var(--consulting-muted);
    font-size: 0.86rem;
    font-weight: 650;
    padding: 0.6rem 0.9rem;
  }

  .consulting-cta {
    border-top: 1px solid var(--consulting-line);
    padding: clamp(4.5rem, 8vw, 7rem) 0;
  }

  .cta-grid {
    grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
  }

  .cta-art {
    aspect-ratio: 16 / 10;
  }

  @media (max-width: 1040px) {
    .hero-grid,
    .process-grid,
    .about-grid,
    .cta-grid {
      grid-template-columns: 1fr;
    }

    .service-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .capability-strip {
      justify-content: start;
      max-width: none;
    }
  }

  @media (max-width: 720px) {
    .consulting-shell {
      width: min(100% - 1.5rem, 1180px);
    }

    .consulting-hero,
    .consulting-section,
    .consulting-cta {
      padding: 3.5rem 0;
    }

    h1 {
      font-size: clamp(2.75rem, 15vw, 4.2rem);
    }

    .hero-actions,
    .hero-actions .btn {
      width: 100%;
    }

    .featured-services,
    .service-grid,
    .process-panel,
    .about-card {
      grid-template-columns: 1fr;
    }

    .featured-card {
      min-height: auto;
    }

    .service-card {
      min-height: auto;
    }

    .hero-art {
      transform: none;
    }

    .process-panel > img {
      aspect-ratio: 16 / 10;
      min-height: 0;
    }
  }
</style>
