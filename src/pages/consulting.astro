---
import Layout from "../layouts/Page.astro";
import {
  INTRO_CALL_LINK,
  consultingServices,
} from "../data/consultingServices";
import type { ConsultingService } from "../data/consultingServices";

const title = "Senior Software Architecture & Security Consulting";
const description =
  "Independent consulting for agentic coding, agentic applications, test-and-eval based development, security, RAG rescue, and modern architecture work.";

const featuredSlugs = ["ai-consulting", "ai-guardrails"];
const featuredServices = featuredSlugs
  .map((slug) => consultingServices.find((service) => service.slug === slug))
  .filter((service): service is ConsultingService => Boolean(service));
const supportingServices = consultingServices.filter(
  (service) => !featuredSlugs.includes(service.slug),
);

const serviceVisuals: Record<string, { accent: string; mark: string; image: string }> = {
  "ai-consulting": {
    accent: "cyan",
    mark: "AI",
    image: "/images/consulting/service-ai-consulting.webp",
  },
  "ai-guardrails": {
    accent: "coral",
    mark: "GR",
    image: "/images/consulting/service-ai-guardrails.webp",
  },
  "supabase-scaling-migration": {
    accent: "amber",
    mark: "SB",
    image: "/images/consulting/service-supabase.webp",
  },
  "rag-rescue": {
    accent: "cyan",
    mark: "RG",
    image: "/images/consulting/service-rag.webp",
  },
  "developer-ai-coding-security": {
    accent: "coral",
    mark: "CS",
    image: "/images/consulting/service-coding-security.webp",
  },
  "enterprise-security-assessment": {
    accent: "amber",
    mark: "ES",
    image: "/images/consulting/service-enterprise-security.webp",
  },
};

const processSteps = [
  {
    title: "Define the target",
    body: "Turn architecture goals, failure cases, and product expectations into tests and evals.",
  },
  {
    title: "Fan out",
    body: "Use agentic coding to explore multiple implementation paths in parallel instead of betting on one.",
  },
  {
    title: "Converge",
    body: "Compare the outputs, combine the strongest pieces, and discard approaches that fail the checks.",
  },
  {
    title: "Ship with proof",
    body: "Land the change with eval coverage, observability, and handoff notes your team can keep using.",
  },
];

const serviceSummaries: Record<string, string> = {
  "ai-consulting":
    "Your AI costs are climbing and the answers are inconsistent. Build the routing, evals, and observability that fix both.",
  "ai-guardrails":
    "Your users are creative. Add policy controls, review paths, and eval gates before they find the fun edge cases.",
  "supabase-scaling-migration":
    "Your auth bill is bigger than your office rent. Let's fix that — with agents exploring the migration in parallel.",
  "rag-rescue":
    "RAG worked great at 500 docs. At 50,000 it's hallucinating confidently. Time to rebuild retrieval properly.",
  "developer-ai-coding-security":
    "AI coding tools are fast. That's the problem. Add sandboxes, access controls, and CI gates before they are.",
  "enterprise-security-assessment":
    "Security debt accumulates quietly until it doesn't. Find the compound risks before they find you.",
};

const trustSignals = [
  {
    value: "$22.5K/mo",
    label: "infrastructure cost removed before it compounded",
  },
  {
    value: "Eval-first",
    label: "pass/fail criteria defined before any agent runs",
  },
  {
    value: "Senior-only",
    label: "no handoffs — I write the code and own the outcome",
  },
  {
    value: "Fixed scope",
    label: "clear deliverables, no open-ended retainers",
  },
];

const proofPoints = [
  "Agentic delivery with evals — not just vibes and hope",
  "Parallel agent exploration instead of one slow serial plan",
  "Production AI design grounded in actual failure cases",
];

const caseProofs = consultingServices
  .filter((service) => service.caseStudy)
  .map((service) => ({
    service: service.navTitle,
    ...service.caseStudy!,
  }));

const fitSignals = [
  "Your AI app works great in the demo. In production it's... creative.",
  "You've been \"adding guardrails next sprint\" for four sprints now",
  "The migration estimate keeps growing and nobody wants to own it",
];
---

<Layout frontmatter={{ title, subTitle: description }}>
  <section class="consulting-hero full-section">
    <div class="consulting-shell consulting-practice-bar">
      <a class="practice-home" href="/">
        <span class="practice-mark">DL</span>
        <span class="practice-brand-copy">
          <strong>DanLevy.net</strong>
          <small>Return to the writing</small>
        </span>
      </a>
      <div class="practice-signal" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </div>
      <div class="practice-label">
        <span>Consulting practice</span>
        <strong>Production AI systems</strong>
      </div>
    </div>

    <div class="consulting-shell hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Independent senior consulting</p>
        <h1>Your AI app works great. Mostly.</h1>
        <p class="hero-sub">
          I help teams go from "it works in the demo" to "it works in
          production" — with agentic coding, eval-driven development, and
          architecture that holds up when real users show up.
        </p>
        <div class="hero-actions">
          <a href={INTRO_CALL_LINK} class="btn btn-primary" target="_blank" rel="noopener">
            <span>Book diagnostic call</span>
            <span class="btn-icon" aria-hidden="true">↗</span>
          </a>
          <a href="#services" class="btn btn-secondary">See services</a>
        </div>
        <ul class="hero-proof" aria-label="Engagement proof">
          {proofPoints.map((point) => <li>{point}</li>)}
        </ul>
      </div>

      <div class="hero-visual-stack">
        <div class="hero-art" aria-hidden="true">
          <img
            src="/images/consulting/consulting-hero-workbench.webp"
            alt=""
            loading="eager"
            decoding="async"
          />
        </div>
        <div class="hero-insight-card">
          <div class="story-beat">
            <span>How it started</span>
            <strong>"GPT-3.5 sure can generate code!"</strong>
          </div>
          <div class="story-beat">
            <span>How it's going</span>
            <strong>Our swarm of Agents completed & tested 183 tickets before lunch. Six regressions were caught and fixed.</strong>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="trust-section full-section" aria-labelledby="trust-heading">
    <div class="consulting-shell trust-grid">
      <div>
        <p class="eyebrow">How I work</p>
        <h2 id="trust-heading">No surprises. Just results.</h2>
      </div>
      <div class="trust-copy">
        <p>
          Every engagement starts with a diagnostic — your logs, costs, incidents, and failure cases — so we both know exactly what we're fixing before any work begins. Deliverables are defined up front. You'll know what done looks like.
        </p>
      </div>
    </div>
    <div class="consulting-shell trust-metrics" aria-label="Consulting proof points">
      {trustSignals.map((signal) => (
        <article class="trust-metric">
          <strong>{signal.value}</strong>
          <span>{signal.label}</span>
        </article>
      ))}
    </div>
  </section>

  <section id="services" class="consulting-section full-section">
    <div class="consulting-shell">
      <div class="section-heading">
        <p class="eyebrow">Services</p>
        <h2>Pick your flavor of "we need help."</h2>
        <p>
          Whether your AI app is too expensive, too unpredictable, or just
          too scary to touch — there's a service for that.
        </p>
      </div>

      <div class="featured-services">
        {featuredServices.map((service) => {
          const visual = serviceVisuals[service.slug];
          return (
            <a class={`featured-card ${visual.accent}`} href={`/consulting/${service.slug}/`}>
              <div class="card-image" aria-hidden="true">
                <img src={visual.image} alt="" loading="eager" decoding="async" />
              </div>
              <div class="service-mark">{visual.mark}</div>
              <p class="card-kicker">{service.kicker}</p>
              <h3>{service.navTitle}</h3>
              <p>{serviceSummaries[service.slug] ?? service.description}</p>
              <span class="card-link">Explore service <span aria-hidden="true">→</span></span>
            </a>
          );
        })}
      </div>

      <div class="service-grid">
        {supportingServices.map((service) => {
          const visual = serviceVisuals[service.slug] ?? {
            accent: "cyan",
            mark: service.navTitle.slice(0, 2).toUpperCase(),
            image: "/images/consulting/service-ai-consulting.webp",
          };
          return (
            <a class={`service-card ${visual.accent}`} href={`/consulting/${service.slug}/`}>
              <div class="supporting-image" aria-hidden="true">
                <img src={visual.image} alt="" loading="eager" decoding="async" />
              </div>
              <div class="service-mark">{visual.mark}</div>
              <p class="card-kicker">{service.kicker}</p>
              <h3>{service.navTitle}</h3>
              <p>{serviceSummaries[service.slug] ?? service.description}</p>
              <span class="card-link">Explore service <span aria-hidden="true">→</span></span>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <section class="consulting-section proof-section full-section">
    <div class="consulting-shell proof-grid">
      <div class="section-heading sticky-heading">
        <p class="eyebrow">Evidence</p>
        <h2>Results, not slides.</h2>
        <p>
          Migrations that used to take quarters. Auth bills that were eating
          the runway. RAG systems that worked great until they didn't. Real
          problems, fixed.
        </p>
      </div>
      <div class="case-stack">
        {caseProofs.map((item) => (
          <article class="case-card">
            <p class="card-kicker">{item.label} · {item.service}</p>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
            <strong>{item.highlight}</strong>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="consulting-section process-section full-section">
    <div class="consulting-shell process-grid">
      <div>
        <p class="eyebrow">How I work</p>
        <h2>Not "throw agents at it."</h2>
        <p class="section-copy">
          Define what done looks like. Let agents explore in parallel.
          Use evals and senior judgment to pick the parts that actually work.
          Ship the thing. Repeat.
        </p>
        <a href={INTRO_CALL_LINK} class="btn btn-primary" target="_blank" rel="noopener">
          <span>Start diagnostic call</span>
          <span class="btn-icon" aria-hidden="true">↗</span>
        </a>
      </div>

      <div class="process-panel">
        <img
          src="/images/consulting/service-rag.webp"
          alt=""
          loading="eager"
          decoding="async"
          aria-hidden="true"
        />
        <div class="steps">
          {processSteps.map((step, index) => (
            <article class="step">
              <span>0{index + 1}</span>
              <div>
                <h3>{step.title}</h3>
                <p>{step.body}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section id="about" class="consulting-section about-section full-section">
    <div class="consulting-shell about-grid">
      <div class="about-card">
        <div class="about-avatar">DL</div>
        <div>
          <p class="eyebrow">Dan Levy</p>
          <h2>Work directly with Dan Levy.</h2>
          <p>
            I work with a small number of companies each year. No account
            managers, no junior handoffs — just senior judgment near the
            implementation. Shaping agentic workflows, reviewing architecture,
            building evals, and helping ship changes your team can actually
            explain to each other.
          </p>
        </div>
      </div>

      <div class="capability-strip">
        <span>AI systems</span>
        <span>Guardrails</span>
        <span>RAG</span>
        <span>Supabase</span>
        <span>Security</span>
      </div>
    </div>
    <div class="consulting-shell fit-panel">
      <p class="eyebrow">Good fit</p>
      <div class="fit-list">
        {fitSignals.map((signal) => <p>{signal}</p>)}
      </div>
    </div>
  </section>

  <section class="consulting-cta full-section">
    <div class="consulting-shell cta-grid">
      <div>
        <p class="eyebrow">Next step</p>
        <h2>Bring the thing your team keeps not finishing.</h2>
        <p>
          The migration everyone's afraid to start. The agentic app that only
          works in staging. The AI product that's expensive and nobody's sure
          why. Let's figure out what's actually wrong and fix it.
        </p>
        <div class="hero-actions">
          <a href={INTRO_CALL_LINK} class="btn btn-primary" target="_blank" rel="noopener">
            <span>Book diagnostic call</span>
            <span class="btn-icon" aria-hidden="true">↗</span>
          </a>
          <a href="/" class="btn btn-secondary">Read the writing</a>
        </div>
      </div>
      <div class="cta-art" aria-hidden="true">
        <img
          src="/images/consulting/service-enterprise-security.webp"
          alt=""
          loading="eager"
          decoding="async"
        />
      </div>
    </div>
  </section>
</Layout>

<style>
  :root {
    --consulting-bg: #05080b;
    --consulting-ink: #f4f0e8;
    --consulting-muted: rgba(244, 240, 232, 0.72);
    --consulting-soft: rgba(244, 240, 232, 0.54);
    --consulting-line: rgba(244, 240, 232, 0.11);
    --consulting-panel: rgba(244, 240, 232, 0.045);
    --consulting-panel-strong: rgba(244, 240, 232, 0.075);
    --consulting-cyan: #28e8df;
    --consulting-coral: #ff73c9;
    --consulting-amber: #b8c7d9;
    --consulting-radius: 18px;
    --consulting-radius-sm: 10px;
    --consulting-shadow: 0 28px 90px rgba(0, 18, 28, 0.58);
    --consulting-motion: 520ms cubic-bezier(0.32, 0.72, 0, 1);
    --consulting-font: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "SF Pro Text", "Segoe UI", sans-serif;
  }

  .full-section {
    grid-column: full-width;
    width: 100%;
  }

  .consulting-hero,
  .consulting-section,
  .consulting-cta,
  .trust-section {
    background: transparent;
    color: var(--consulting-ink);
  }

  .consulting-shell {
    width: min(1180px, calc(100% - 3rem));
    margin: 0 auto;
  }

  .consulting-hero {
    padding: clamp(4rem, 8vw, 7rem) 0 5rem;
    overflow: hidden;
  }

  :global(.top-header .header-nav > h2) {
    text-shadow: none !important;
  }

  :global(.top-header .header-nav > h2 .title) {
    animation: consulting-site-title-drift 7s ease-in-out infinite alternate !important;
    background:
      linear-gradient(105deg, #f6fbff 0%, #c8d6e5 28%, #74d8ca 56%, #9fb8ff 78%, #f6fbff 100%) !important;
    background-clip: text !important;
    background-size: 230% 100% !important;
    color: transparent !important;
    filter: drop-shadow(0 16px 24px rgba(1, 18, 22, 0.42)) !important;
    text-shadow: none !important;
    -webkit-text-stroke: 0.55px rgba(246, 251, 255, 0.26) !important;
  }

  :global(.top-header .header-nav > h2:hover) {
    text-shadow: none !important;
    transform: translateY(-1px);
  }

  :global(.top-header .header-nav > h2 a img) {
    border-color: rgba(246, 251, 255, 0.72) !important;
    box-shadow:
      0 12px 28px rgba(0, 18, 28, 0.32),
      0 0 0 1px rgba(116, 216, 202, 0.18) !important;
  }

  :global(.top-header .header-nav > h2:hover a img) {
    border-color: rgba(246, 251, 255, 0.86) !important;
    box-shadow:
      0 14px 32px rgba(0, 18, 28, 0.36),
      0 0 0 1px rgba(236, 161, 176, 0.24) !important;
  }

  .consulting-hero::after {
    background: linear-gradient(90deg, transparent, rgba(40, 232, 223, 0.75), rgba(255, 115, 201, 0.62), transparent);
    content: "";
    display: block;
    height: 1px;
    margin: clamp(4rem, 7vw, 6rem) auto 0;
    opacity: 0.58;
    width: min(1180px, calc(100% - 3rem));
  }

  .consulting-practice-bar {
    align-items: center;
    display: flex;
    gap: clamp(1rem, 2.5vw, 1.5rem);
    justify-content: space-between;
    margin-bottom: clamp(3rem, 6vw, 5.5rem);
    min-height: 4.5rem;
    position: relative;
  }

  .consulting-practice-bar::before {
    background:
      linear-gradient(90deg, rgba(40, 232, 223, 0.18), transparent 38%),
      linear-gradient(180deg, rgba(244, 240, 232, 0.07), rgba(244, 240, 232, 0.018));
    border: 1px solid rgba(244, 240, 232, 0.09);
    border-radius: 16px;
    box-shadow:
      inset 0 1px 0 rgba(244, 240, 232, 0.08),
      0 18px 54px rgba(0, 18, 28, 0.22);
    content: "";
    inset: -0.55rem -0.65rem;
    opacity: 0.8;
    pointer-events: none;
    position: absolute;
  }

  .practice-home {
    align-items: center;
    background:
      linear-gradient(135deg, rgba(244, 240, 232, 0.13), rgba(244, 240, 232, 0.055)),
      rgba(5, 8, 11, 0.74);
    border: 1px solid rgba(244, 240, 232, 0.13);
    border-radius: 12px;
    box-shadow:
      inset 0 1px 0 rgba(244, 240, 232, 0.1),
      0 16px 36px rgba(0, 18, 28, 0.25);
    color: var(--consulting-ink);
    display: inline-flex;
    gap: 0.75rem;
    min-width: 13rem;
    padding: 0.6rem 0.95rem 0.6rem 0.6rem;
    position: relative;
    text-decoration: none;
    transition: border-color var(--consulting-motion), background var(--consulting-motion), box-shadow var(--consulting-motion), transform var(--consulting-motion);
    z-index: 1;
  }

  .practice-home:hover {
    background:
      linear-gradient(135deg, rgba(244, 240, 232, 0.16), rgba(244, 240, 232, 0.07)),
      rgba(5, 8, 11, 0.86);
    border-color: rgba(40, 232, 223, 0.36);
    box-shadow:
      inset 0 1px 0 rgba(244, 240, 232, 0.13),
      0 20px 42px rgba(0, 18, 28, 0.3),
      0 0 0 1px rgba(40, 232, 223, 0.08);
    transform: translateY(-2px);
  }

  .practice-home:focus-visible {
    outline: 2px solid rgba(40, 232, 223, 0.78);
    outline-offset: 4px;
  }

  .practice-mark {
    align-items: center;
    background:
      radial-gradient(circle at 30% 25%, rgba(244, 240, 232, 0.3), transparent 35%),
      linear-gradient(135deg, rgba(40, 232, 223, 0.2), rgba(159, 184, 255, 0.11));
    border: 1px solid rgba(244, 240, 232, 0.18);
    border-radius: 10px;
    box-shadow:
      inset 0 1px 0 rgba(244, 240, 232, 0.12),
      0 10px 22px rgba(0, 18, 28, 0.24);
    display: flex;
    flex: 0 0 auto;
    font-size: 0.76rem;
    font-weight: 800;
    height: 2.45rem;
    justify-content: center;
    letter-spacing: 0;
    width: 2.45rem;
  }

  .practice-brand-copy strong,
  .practice-brand-copy small {
    display: block;
    line-height: 1.1;
  }

  .practice-brand-copy strong {
    font-size: 0.92rem;
    letter-spacing: 0;
  }

  .practice-brand-copy small {
    color: var(--consulting-soft);
    font-size: 0.7rem;
    font-weight: 650;
    margin-top: 0.18rem;
  }

  .practice-signal {
    align-items: center;
    display: grid;
    flex: 1 1 auto;
    gap: 0.65rem;
    grid-template-columns: minmax(2rem, 1fr) auto minmax(2rem, 1fr);
    min-width: 8rem;
    position: relative;
    z-index: 1;
  }

  .practice-signal span {
    display: block;
  }

  .practice-signal span:first-child,
  .practice-signal span:last-child {
    background: linear-gradient(90deg, transparent, rgba(244, 240, 232, 0.26), rgba(40, 232, 223, 0.34));
    height: 1px;
  }

  .practice-signal span:last-child {
    background: linear-gradient(90deg, rgba(40, 232, 223, 0.34), rgba(244, 240, 232, 0.18), transparent);
  }

  .practice-signal span:nth-child(2) {
    background: rgba(40, 232, 223, 0.9);
    border-radius: 999px;
    box-shadow:
      0 0 0 5px rgba(40, 232, 223, 0.07),
      0 0 26px rgba(40, 232, 223, 0.42);
    height: 0.38rem;
    width: 0.38rem;
  }

  .practice-label {
    border-left: 1px solid rgba(244, 240, 232, 0.14);
    min-width: 13.5rem;
    padding-left: clamp(1rem, 2vw, 1.4rem);
    position: relative;
    text-align: right;
    z-index: 1;
  }

  .practice-label span,
  .practice-label strong {
    display: block;
    line-height: 1.1;
  }

  .practice-label span {
    color: rgba(40, 232, 223, 0.82);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0;
    margin-bottom: 0.35rem;
    text-transform: uppercase;
  }

  .practice-label strong {
    color: rgba(244, 240, 232, 0.86);
    font-size: clamp(0.98rem, 1.4vw, 1.18rem);
    font-weight: 620;
    letter-spacing: 0;
  }

  .hero-grid,
  .process-grid,
  .about-grid,
  .cta-grid,
  .trust-grid,
  .proof-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
  }

  .eyebrow,
  .card-kicker {
    color: var(--consulting-cyan);
    font-family: var(--consulting-font);
    font-size: 0.72rem;
    font-weight: 650;
    letter-spacing: 0.08em;
    line-height: 1.2;
    margin: 0 0 1.15rem;
    text-transform: uppercase;
  }

  .eyebrow {
    color: rgba(40, 232, 223, 0.88);
  }

  h1,
  h2,
  h3,
  p,
  a,
  span,
  strong,
  li {
    font-family: var(--consulting-font);
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
    text-shadow: none !important;
  }

  h1 {
    max-width: 720px;
    animation: consulting-title-drift 8s ease-in-out infinite alternate;
    background:
      linear-gradient(105deg, #f6fbff 0%, #c8d6e5 22%, #79d8cc 48%, #9fb8ff 72%, #f6fbff 100%);
    background-clip: text;
    background-size: 220% 100%;
    color: transparent;
    font-size: clamp(3.25rem, 6.1vw, 5.65rem);
    font-weight: 590;
    letter-spacing: -0.058em;
    line-height: 0.95;
    margin-bottom: 1.55rem;
    text-shadow:
      0 1px 0 rgba(246, 251, 255, 0.18),
      0 22px 54px rgba(4, 20, 24, 0.56),
      0 0 44px rgba(121, 216, 204, 0.16);
    text-wrap: balance;
    -webkit-text-stroke: 1px rgba(246, 251, 255, 0.2);
  }

  h2 {
    color: var(--consulting-ink);
    font-size: clamp(2.45rem, 4.8vw, 4.8rem);
    font-weight: 620;
    letter-spacing: -0.058em;
    line-height: 0.98;
    margin-bottom: 1.05rem;
    max-width: 13ch;
