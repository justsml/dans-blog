---
import Post from "../layouts/Post.astro";
import { render, type CollectionEntry } from "astro:content";
import { PostCollections } from "../shared/postsCache";
import { writeRedirectManifest } from "../scripts/redirectManager";

export async function getStaticPaths() {
  const paths = PostCollections.getStaticPaths();
  writeRedirectManifest(PostCollections.getRedirectSourcePosts());
  return paths;
}

type Props = CollectionEntry<"posts"> & { slug: string };

const post = Astro.props as Props;
const results = await render(post);
const { Content } = results;
---

<Post sourcePath={post.id} slug={post.slug} frontmatter={{ ...post.data }}>
  <Content />
</Post>
