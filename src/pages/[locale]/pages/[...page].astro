---
import type { PagePath, ArticlePost } from "../../../types";
import { PostCollections } from "../../../shared/postsCache";
import {
  buildArchivePagePaths,
  getArchiveArticleListCtaOccurrence,
  getArchiveNextUrl,
  type ArchiveStaticPath,
  type ArchiveRouteProps,
} from "../../../shared/archivePagination";
import { ArticleCard } from "../../../components/ArticleCard";
import ArticleListSkeleton from "../../../components/ArticleListSkeleton.astro";
import ArticleListConsultingCTA from "../../../components/ArticleListConsultingCTA.astro";
import { PaginateFunction } from "astro";
import { ACTIVE_LOCALES, type ActiveLocale } from "../../../shared/i18n";

export const partial = true;

type Props = ArchiveRouteProps<ActiveLocale> & { locale: ActiveLocale };

export async function getStaticPaths({
  paginate,
}: {
  paginate: PaginateFunction;
}) {
  const pages = ACTIVE_LOCALES.flatMap((locale) =>
    buildArchivePagePaths({
      posts: PostCollections.getPostsForLocale(locale) as ArticlePost[],
      paginate,
      toStaticPaths: PostCollections.getStaticPaths as (
        posts: ArticlePost[],
      ) => ArchiveStaticPath<ArticlePost>[],
      params: { locale },
      props: { locale },
    }),
  );

  return pages as unknown as PagePath[];
}

const {
  page: { data, currentPage, lastPage, url },
  pageUrlSuffix,
  locale,
} = Astro.props as Props;

const nextUrl = getArchiveNextUrl({
  currentPage,
  lastPage,
  next: url.next,
  pageUrlSuffix,
});
---

{
  data.map(({ props }: any, index) => {
    const ctaOccurrence = getArchiveArticleListCtaOccurrence(index, currentPage);

    return (
    <>
      <ArticleCard article={props as ArticlePost} width={200} locale={locale} />
      {ctaOccurrence !== null && (
        <ArticleListConsultingCTA
          category={ctaOccurrence === 1 ? undefined : (props as ArticlePost).data.category}
          compact
          pageCount={ctaOccurrence}
          singleColumn
        />
      )}
    </>
    );
  })
}

<ArticleListSkeleton nextUrl={nextUrl} />
