---
import Page from "../layouts/Page.astro";

import { PostCollections } from "../shared/postsCache.ts";
import { ArticleCard } from "../components/ArticleCard";
import ArticleListConsultingCTA from "../components/ArticleListConsultingCTA.astro";
// import FloatingLines from "../components/FloatingLines";
import type { ArticlePost } from "../types";
import omit from "lodash/omit";
import { pageSize } from "../shared/pagination";
import "@/styles/nav.css";
import "@/styles/global.css";
import { SITE_SEO_DESCRIPTION, SITE_TITLE } from "../consts.ts";
// import ArticleFilterLinks from "../components/ArticleFilterLinks.astro";

let posts = PostCollections.getPosts().map((p) =>
  omit(p as ArticlePost, [
    "data.body",
    "data.cover",
    "data.cover_icon",
  ])
)
.filter((p) => !p.data?.unlisted && !p.data?.hidden) as ArticlePost[];

const defaultNextUrl = "/pages/2-date-desc.html";

const nextPageAttrs = defaultNextUrl
  ? {
      "hx-get": defaultNextUrl,
      "hx-trigger": "revealed",
      "hx-swap": "afterend",
    }
  : {};
// 
posts = posts.slice(0, pageSize - 1);
const consultingCtaIndex = Math.min(3, Math.max(posts.length - 2, 0));

const defaultFullTitle = `${SITE_TITLE} | ${SITE_SEO_DESCRIPTION}`;
---

<Page title={defaultFullTitle} subTitle={SITE_SEO_DESCRIPTION} className="home-page">
  <!-- <div class="background-effect full-width" aria-hidden="true">
    <FloatingLines
      client:load
      enabledWaves={["top", "middle", "bottom"]}
      lineCount={8}
      lineDistance={8}
      bendRadius={14}
      bendStrength={10.5}
      interactive
      parallax={true}
      animationSpeed={3.2}
      gradientStart="hsl(var(--neon-pink))"
      gradientMid="hsl(var(--neon-cyan))"
      gradientEnd="hsl(var(--neon-purple))"
      backgroundColor="hsl(var(--background))"
      backgroundAccentColor="hsl(var(--bg-dark))"
      backgroundGlowColor="hsl(var(--neon-cyan))"
    />
  </div> -->
  <section class="home-explainer" aria-labelledby="home-title">
    <p class="eyebrow">Field notes</p>
    <h1 id="home-title">Notes from where the docs run out.</h1>
    <p>
      AI systems, JavaScript, security, databases, and bug fixes worth remembering.
    </p>
  </section>

  <section class="home-link-spotlight" aria-labelledby="home-link-spotlight-title">
    <div class="spotlight-copy">
      <p class="eyebrow">Resources</p>
      <h2 id="home-link-spotlight-title">Useful paths</h2>
      <p>
        Consulting work and open source notes.
      </p>
    </div>
    <div class="spotlight-actions" aria-label="Featured links">
      <a class="spotlight-link consulting-link" href="/consulting/">
        <span class="link-kicker">Consulting</span>
        <span class="link-title">Build better AI systems</span>
      </a>
      <a class="spotlight-link oss-link" href="/open-source-journal/">
        <span class="link-kicker">Open Source Log</span>
        <span class="link-title">Follow the commits</span>
      </a>
    </div>
  </section>

  <section class="archive-intro" aria-labelledby="archive-title">
    <div>
      <p class="eyebrow">Latest writing</p>
      <h2 id="archive-title">Recent writing</h2>
      <p>
        Newest first.
      </p>
    </div>
  </section>

  <div class:list={["article-list"]}>
    {
      posts
        // .filter(
        //   ({data: {unlisted, hidden}}) => unlisted !== true && hidden !== true
        // )
        .map((props: any, index) =>
          <>
            {index === posts.length - 1 ? (
              <ArticleCard
                article={props as ArticlePost}
                width={200}
                {...nextPageAttrs}
              />
            ) : (
              <ArticleCard article={props as ArticlePost} width={200} />
            )}
            {index === consultingCtaIndex && <ArticleListConsultingCTA pageCount={1} />}
          </>
        )
    }
    <!-- {nextPageAttrs && <a hx-get={defaultNextUrl} hx-swap="afterend">Next</a>} -->
  </div>
</Page>

<script>
  let htmxRequested = false;

  function loadHtmx() {
    if (htmxRequested || document.querySelector("script[data-x-htmx-tag]")) return;
    htmxRequested = true;

    const scriptEl = document.createElement("script");
    scriptEl.setAttribute("data-x-htmx-tag", "");
    scriptEl.setAttribute("defer", "");
    scriptEl.src = "/js/htmx.min.js";
    scriptEl.onload = () => {
      // @ts-expect-error - htmx is a global
      window.htmx?.process(document.body);
    };

    document.body.appendChild(scriptEl);
  }

  function scheduleHtmxLoad() {
    const target = document.querySelector("[hx-get][hx-trigger='revealed']");
    if (!target) return;

    if ("IntersectionObserver" in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          if (!entries.some((entry) => entry.isIntersecting)) return;
          observer.disconnect();
          loadHtmx();
        },
        { rootMargin: "0px 0px" },
      );
      observer.observe(target);
      return;
    }

    if ("requestIdleCallback" in globalThis) {
      globalThis.requestIdleCallback(loadHtmx, { timeout: 1800 });
    } else {
      globalThis.setTimeout(loadHtmx, 900);
    }
  }

  document.addEventListener("astro:page-load", scheduleHtmxLoad);

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", scheduleHtmxLoad, { once: true });
  } else {
    scheduleHtmxLoad();
  }
</script>

<style>
  .background-effect {
    height: min(600px, 62vh);
    inset: 0 auto auto 50%;
    min-height: 360px;
    overflow: hidden;
    padding-inline: 0;
    position: absolute;
    transform: translateX(-50%);
    width: 100vw;
    z-index: 0;
  }

  .background-effect::after {
    background: linear-gradient(
      180deg,
      hsl(var(--background) / 0) 0%,
      hsl(var(--background) / 0.28) 72%,
      hsl(var(--background)) 100%
    );
    content: "";
    inset: 0;
    pointer-events: none;
    position: absolute;
    z-index: 1;
  }

  .background-effect :global(astro-island),
  .background-effect :global(.floating-lines-container) {
    display: block;
    height: 100%;
    width: 100%;
  }

  :global(main.home-page) {
    --site-shell-gutter: clamp(1rem, 5vw, 2rem);
    --site-shell-width: 1180px;
    --content-max-width: var(--site-shell-width);
    --breakout-max-width: var(--site-shell-width);
    --padding-inline: 0;
    isolation: isolate;
    position: relative;
  }

  .home-explainer,
  .home-link-spotlight,
  .archive-intro,
  .article-list {
    grid-column: 1 / -1;
    justify-self: center;
    position: relative;
    width: min(calc(100vw - (var(--site-shell-gutter) * 2)), var(--site-shell-width));
    z-index: 1;
  }

  .home-explainer,
  .archive-intro {
    margin-inline: auto;
    max-width: none;
  }

  .home-explainer {
    display: grid;
    gap: 0.45rem;
    margin-top: clamp(0.5rem, 2vw, 1.5rem);
    padding-block: clamp(0.75rem, 2vw, 1.5rem) clamp(0.35rem, 1vw, 0.75rem);
  }

  .home-explainer h1,
  .archive-intro h2 {
    color: var(--clr-muted-100);
    font-family: "Raleway", sans-serif;
    letter-spacing: 0;
    line-height: 1.05;
    margin: 0;
    text-shadow: none;
    text-wrap: balance;
  }

  .home-explainer h1 {
    font-size: clamp(1.35rem, 3vw, 2.25rem);
    font-weight: 700;
    max-width: 30ch;
    text-wrap: wrap;
  }

  .home-explainer p:not(.eyebrow),
  .spotlight-copy p:not(.eyebrow),
  .archive-intro p:not(.eyebrow) {
    color: hsl(var(--muted-foreground));
    font-size: clamp(0.98rem, 1.15vw, 1.08rem);
    line-height: 1.65;
    margin: 0;
    max-width: 62ch;
  }

  .home-link-spotlight {
    --spotlight-cyan: var(--neon-cyan);
    --spotlight-pink: var(--neon-pink);
    --spotlight-lime: #b8ff5f;
    --spotlight-ink: rgb(5, 8, 10);
    align-items: center;
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
    isolation: isolate;
    margin: 0.75rem auto 1.75rem;
    max-width: none;
    overflow: hidden;
    position: relative;
  }

  .home-link-spotlight::before {
    background:
      linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.28), transparent),
      linear-gradient(90deg, var(--spotlight-cyan), var(--spotlight-lime), var(--spotlight-pink));
    content: "";
    height: 1px;
    inset: 0 auto auto 0;
    opacity: 0.82;
    position: absolute;
    width: 100%;
  }

  .spotlight-copy {
    display: grid;
    gap: 0.2rem;
    padding-top: 1.4rem;
  }

  .spotlight-copy h2 {
    color: var(--clr-muted-100);
    font-size: 1.75rem;
    letter-spacing: 0;
    line-height: 1.1;
    margin: 0;
    text-wrap: balance;
  }

  .eyebrow {
    color: var(--spotlight-cyan);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    margin: 0;
    text-transform: uppercase;
  }

  .spotlight-actions {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: 1fr;
  }

  .archive-intro {
    align-items: end;
    display: grid;
    gap: 1rem;
    grid-template-columns: minmax(0, 1fr);
    margin-top: clamp(1.5rem, 4vw, 3rem);
  }

  .archive-intro h2 {
    font-size: clamp(1.55rem, 3vw, 2.35rem);
    font-weight: 700;
    max-width: 18ch;
  }

  .article-list {
    margin-top: clamp(1rem, 3vw, 2rem);
    max-width: none;
  }

  .spotlight-link {
    --link-accent: var(--spotlight-cyan);
    align-items: center;
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.018)) padding-box,
      linear-gradient(var(--spotlight-ink), var(--spotlight-ink)) padding-box,
      conic-gradient(from var(--spin-angle, 0deg), var(--link-accent), rgba(255, 255, 255, 0.12) 34%, var(--spotlight-pink), rgba(255, 255, 255, 0.12) 68%, var(--link-accent)) border-box;
    border: 1px solid transparent;
    border-radius: 8px;
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.12) inset,
      0 0 1rem color-mix(in srgb, var(--link-accent), transparent 84%);
    color: var(--clr-muted-100);
    display: grid;
    min-height: 5.6rem;
    overflow: hidden;
    padding: 1rem;
    position: relative;
    text-decoration: none;
    transform: translateZ(0);
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }

  .spotlight-link::before {
    background: linear-gradient(110deg, transparent 20%, rgba(255, 255, 255, 0.22), transparent 48%);
    content: "";
    inset: 0;
    position: absolute;
    transform: translateX(-120%);
    transition: transform 520ms ease;
  }

  .spotlight-link::after {
    background: linear-gradient(90deg, var(--link-accent), transparent);
    block-size: 3px;
    content: "";
    inset: auto 1rem 0.85rem 1rem;
    opacity: 0.85;
    position: absolute;
    transform: scaleX(0.36);
    transform-origin: left;
    transition: transform 180ms ease;
  }

  .spotlight-link:hover,
  .spotlight-link:focus-visible {
    border-color: color-mix(in srgb, var(--link-accent), white 18%);
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.08) inset,
      0 0 1.5rem color-mix(in srgb, var(--link-accent), transparent 68%);
    color: white;
    outline: none;
    transform: translateY(-2px);
  }

  .spotlight-link:hover::before,
  .spotlight-link:focus-visible::before {
    transform: translateX(120%);
  }

  .spotlight-link:hover::after,
  .spotlight-link:focus-visible::after {
    transform: scaleX(1);
  }

  .oss-link {
    --link-accent: var(--spotlight-lime);
  }

  .link-kicker,
  .link-title {
    position: relative;
    z-index: 1;
  }

  .link-kicker {
    color: var(--link-accent);
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .link-title {
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: 0;
    line-height: 1.08;
    max-width: 13ch;
  }

  @property --spin-angle {
    syntax: "<angle>";
    inherits: false;
    initial-value: 0deg;
  }

  @media (prefers-reduced-motion: no-preference) {
    .spotlight-link {
      animation: border-spin 7s linear infinite;
    }

    .oss-link {
      animation-direction: reverse;
      animation-duration: 8.5s;
    }
  }

  @keyframes border-spin {
    to {
      --spin-angle: 360deg;
    }
  }

  @media (min-width: 720px) {
    .home-link-spotlight {
      grid-template-columns: minmax(15rem, 0.72fr) minmax(25rem, 1fr);
      margin-top: 1.25rem;
    }

    .spotlight-actions {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .spotlight-copy {
      padding-block: 1.2rem;
    }

    .spotlight-copy h2 {
      font-size: 2rem;
    }

    .link-title {
      font-size: 1.42rem;
    }
  }
</style>
