---
import CategoryPage from "./_CategoryPage.astro";
import { PostCollections } from "../../shared/postsCache";

export async function getStaticPaths() {
  return PostCollections.getStaticPathsCategoryList();
}

const { category, count } = Astro.props as {
  category: string;
  count: number;
};
---

<CategoryPage category={category} count={count} />
