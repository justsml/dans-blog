---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import AnalyticsTag from "../components/AnalyticsTag.astro";
import { default as defaultSocialBanner } from "../assets/social-banner.webp";
import clsx from "clsx";
import SiteLinkedData from "../components/Seo/SiteLinkedData.astro";
import {
  DEFAULT_LOCALE,
  getHtmlLang,
  getPageAlternates,
  getLocalizedPagePath,
  getUnlocalizedPagePath,
  type Locale,
} from "../shared/i18n";
// import { moveInOutTransition } from "../components/TransitionAnimations.ts";

const { title, subTitle } = Astro.props.frontmatter! || Astro.props;
// const url = Astro.url.pathname;

// console.log("Astro.props", Astro.props);
type Props = {
  title?: string;
  subTitle?: string;
  frontmatter?: Record<string, any>;
  socialImage?: string | ImageMetadata;
  className?: string;
  pagefindBody?: boolean;
  locale?: Locale;
  canonicalPath?: string;
  alternates?: Array<{ locale: string; href: string }>;
};

const socialBanner = Astro.props.socialImage || defaultSocialBanner;
const pagefindBody = Astro.props.pagefindBody ?? false;
const locale = Astro.props.locale ?? DEFAULT_LOCALE;
const basePagePath = getUnlocalizedPagePath(Astro.url.pathname);
const canonicalPath = Astro.props.canonicalPath ?? getLocalizedPagePath(basePagePath, locale);
const alternates = Astro.props.alternates ?? getPageAlternates(basePagePath);
---

<html lang={getHtmlLang(locale)}>
  <head>
    <BaseHead
      title={title}
      description={`${subTitle}`}
      image={socialBanner}
      canonicalPath={canonicalPath}
      alternates={alternates}
    />
  </head>
  <body>
    <Header className="content-grid" locale={locale} />
    <main
      class={clsx("content-grid", Astro.props.className)}
      data-pagefind-body={pagefindBody ? true : undefined}
    >
      <slot name="default" />
    </main>
    <Footer locale={locale} />
    <AnalyticsTag />
    <SiteLinkedData />
  </body>
</html>
