---
// import { fade } from 'astro:transitions';
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import AnalyticsTag from "../components/AnalyticsTag.astro";
import { GitHubIssueComments } from "../components/Comments";
import { CreatedModifiedLabel } from "../components/CreatedModifiedLabel";
import socialBanner from "../assets/social-banner.webp";

import { Image, getImage } from "astro:assets";
import type { ImageMetadata } from "astro";
import CategoryLink from "../components/CategoryLink.astro";
import { ShareCounters } from "../components/ShareUI";
import PostLinkedData from "../components/Seo/PostLinkedData.astro";
import ConsultingCTA from "../components/ConsultingCTA.astro";

type Props = {
  sourcePath: string;
  children: any[];

  slug: string;

  frontmatter?: {
    title: string;
    subTitle?: string;
    commentsKeyOverride?: string;
    date?: string;
    modified?: string;
    tags?: string[];
    social_image?: unknown;
    cover?: unknown;
    cover_full_width?: unknown;
    category?: string;
    related?: string[];
  };
};

const {
  title,
  subTitle,
  cover,
  cover_full_width,
  category,
  date,
  modified,
  commentsKeyOverride,
  related,
  social_image,
} = Astro.props.frontmatter! || Astro.props;

const slug = Astro.props.slug;

const modDate = modified ? new Date(modified) : null;
const modTime = modDate ? modDate.toISOString().split("T")[0] : "";
const pubTime = date ? new Date(date).toISOString().split("T")[0] : "";

// Add type guard for ImageMetadata
const isImageMetadata = (img: any): img is ImageMetadata =>
  typeof img === "object" && "src" in img && "width" in img && "height" in img;

const coverUrl = isImageMetadata(cover)
  ? (cover as ImageMetadata)
  : typeof cover === "string"
    ? cover
    : isImageMetadata(social_image)
      ? social_image
      : socialBanner;

const subTitleHtml = subTitle?.replace(/`([^`]+)`/g, "<code>$1</code>");
const commentsKey = commentsKeyOverride || new URL(Astro.request.url).pathname;

const responsiveImgSizes_fullWidth = {
  widths: [720, 1280, 1920],
  sizes: `
    (max-width: 600px) 100vw,
    (max-width: 1200px) 80vw,
    60vw`,
};
const responsiveImgSizes_breakRight = {
  widths: [800, 1440, 1920],
  sizes: `
    (max-width: 600px) 100vw,
    (max-width: 1200px) 80vw,
    60vw`,
};

// Compute a preload hint for the above-the-fold hero image so the browser
// discovers it during the initial HTML parse rather than after layout.
const _heroSrc = isImageMetadata(cover_full_width)
  ? (cover_full_width as ImageMetadata)
  : isImageMetadata(cover)
    ? (cover as ImageMetadata)
    : null;

const heroPreload = _heroSrc
  ? await getImage({
      src: _heroSrc,
      widths: isImageMetadata(cover_full_width) ? [720, 1280, 1920] : [800, 1440, 1920],
      format: "webp",
    }).catch(() => null)
  : null;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={`${subTitle}`} image={coverUrl} />
    {modTime && <meta http-equiv="last-modified" content={modTime} />}
    {modTime && <meta property="article:modified_time" content={modTime} />}
    {pubTime && <meta property="article:published_time" content={pubTime} />}
    {/* Preload the LCP hero image — discovered at parse time, before layout */}
    {heroPreload && (
      <link
        rel="preload"
        as="image"
        href={heroPreload.src}
        imagesrcset={heroPreload.srcSet.attribute}
        imagesizes="(max-width: 600px) 100vw, (max-width: 1200px) 80vw, 60vw"
        fetchpriority="high"
      />
    )}
  </head>
  <body class="post-page">
    <Header className="content-grid article" date={date} modified={modified} />
    <main
      data-pagefind-body
      class="content-grid article h-entry h-recipe"
      style={{
        
      }}
    >
      {
        title && (
          <h1
            class="p-name"
            data-pagefind-meta="title"
            style={{
              viewTransitionName: `article-${`${slug}`.replace(/^\/*|\/*$/g, "")}`,
            }}
          >
            {title}
          </h1>
        )
      }
      {
        subTitleHtml && (
          <h2 class="p-summary" set:html={subTitleHtml} />
        )
      }

      <aside class="skinny screenshot-hidden">
        <div class="info">
          <CreatedModifiedLabel date={date} modified={modified} />
          <CategoryLink category={category} class:list={"p-category"} />
        </div>
      </aside>

      {
        cover_full_width &&
        typeof cover_full_width === "object" &&
        "src" in cover_full_width ? (
          <div class="banner-wrapper full-width">
            {/* Ghost image: invisible, only holds layout space — deprioritise it */}
            <Image
              class="ghost-image"
              src={cover_full_width as ImageMetadata}
              alt=""
              aria-hidden="true"
              loading="lazy"
              {...responsiveImgSizes_fullWidth}
            />
            {/* LCP target — eager + high priority, preloaded in <head> */}
            <Image
              class="flow u-photo banner-image"
              src={cover_full_width as ImageMetadata}
              alt={title}
              format="webp"
              loading="eager"
              fetchpriority="high"
              {...responsiveImgSizes_fullWidth}
            />
          </div>
        ) : (
          cover &&
          typeof cover === "object" &&
          "src" in cover && (
            <div class="hero-image">
              <div class="hero-image-wrapper">
                {/* LCP target — eager + high priority, preloaded in <head> */}
                <Image
                  class="u-photo"
                  src={cover as ImageMetadata}
                  alt={title}
                  loading="eager"
                  fetchpriority="high"
                  {...responsiveImgSizes_breakRight}
                />
              </div>
            </div>
          )
        )
      }

      <ConsultingCTA category={category} slug={slug} />

      <slot />

      <ShareCounters
        client:visible
        url={Astro.request.url}
        className="share-counter-links"
      />
    </main>

    <div class="comments-wrapper full-width default-links">
      <GitHubIssueComments client:visible path={commentsKey} />
    </div>
    <Footer
      slugs={related}
      excludeSlugs={[slug]}
      currentSlug={slug}
      tags={Astro.props.frontmatter?.tags}
      category={category}
      editSourcePath={Astro.props.sourcePath}
    />
    <AnalyticsTag />
  </body><PostLinkedData
    title={title}
    description={subTitle!}
    date={pubTime}
    modified={modTime}
    slug={slug}
    tags={Astro.props.frontmatter?.tags?.join(", ") ?? ""}
    imageUrl={coverUrl}
  />
  <link
    rel="stylesheet"
    href="/files/fonts.css"
    media="print"
    onload="this.media='all'"
  />
  <script>
    import { installPostEnhancementLifecycle } from "../layouts/postEnhancements";

    installPostEnhancementLifecycle();

    /**
     * - Added a check to **prevent double-initialization**. Previously, the script ran twice (once on load, once on hydration), causing the "flash and vanish" bug.
     * - Removed conflicting auto-initialization code.
     * - **Final Window Reveal Logic**:
     *     - **Fixed 200px Window**: The banner stays exactly 200px tall with `overflow: hidden`.
     *     - **Native Scale (Un-resized)**: The shader now uses aspect-correct logic (similar to `object-fit: cover`). The image is NOT stretched or zoomed to fit the 200px height.
     *     - **Interactive Pan**: As you scroll, the "window" pans over the full-scale image, revealing what was hidden.
     *     - **Premium Polish & Accessibility**:
     *         - **Subtle Distortion**: The liquid effects have been toned down for a more professional, sophisticated look.
     *         - **Mouse Velocity**: The distortion now reacts to both scroll speed and **how fast you move your mouse** over the banner.
     *         - **Reduced Motion Support**: Respects the `prefers-reduced-motion` system setting by disabling animations for an accessible experience.
     * -   **Load & Style Polish**:
     *     -   **Neon Borders**: Added top and bottom 1px neon pink borders (`--primary`) with a subtle glow.
     *     -   **Jump-Free Load**: The banner now initializes its scroll position immediately, eliminating the "sliding into place" behavior on refresh.
     *     -   **Smooth Reveal**: The effect now fades in over 800ms for a more cinematic entrance.
     *
     * This combination decouples the page layout from the WebGL rendering, ensuring a stable, performant experience.
     */
  </script>

  <style is:global>
    /* WebGL Banner Effect Styles */
    .banner-webgl-canvas {
      display: block;
      width: 100%;
      height: auto;
      position: relative;
      z-index: 1;
      image-rendering: -webkit-optimize-contrast;
      image-rendering: crisp-edges;
      transform: translateZ(0);
      will-change: transform, opacity;
      opacity: 1;
      transition: opacity 0.3s ease-out;
    }

    .full-width.banner-image,
    .hero-image-wrapper {
      position: relative;
      isolation: isolate;
    }

    .banner-image[style*="opacity: 0"],
    .hero-image img[style*="opacity: 0"] {
      pointer-events: none;
      user-select: none;
    }

    .full-width {
      contain: layout style paint;
    }

    .hero-image {
      contain: layout style paint;
    }

    @media (max-width: 768px) {
      .banner-webgl-canvas {
        image-rendering: auto;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .banner-webgl-canvas {
        animation: none !important;
        transition: none !important;
      }
    }

    @media (prefers-color-scheme: dark) {
      .banner-webgl-canvas {
        filter: brightness(0.95) contrast(1.05);
      }
    }

    @media print {
      .banner-webgl-canvas {
        display: none !important;
      }
      
      .banner-image[style*="opacity: 0"],
      .hero-image img[style*="opacity: 0"] {
        opacity: 1 !important;
        position: static !important;
        pointer-events: auto !important;
      }
    }

    .banner-webgl-canvas,
    .full-width.banner-image,
    .hero-image-wrapper {
      backface-visibility: hidden;
      perspective: 1000px;
    }

    /* WebGL Wrapper Layout */
    .banner-wrapper.full-width {
      display: block; /* Override grid */
      margin-bottom: 2rem;
      position: relative;
      isolation: isolate;
      height: 200px; /* Fixed height requested */
      overflow: hidden; /* Ensure crop */
      border-top: 1px solid var(--primary);
      border-bottom: 1px solid var(--primary);
      box-shadow: inset 0 0 15px rgba(255, 0, 153, 0.1); /* Subtle neon glow */
    }

    /* Ghost image props open the container */
    .ghost-image {
      display: block;
      width: 100%;
      height: auto;
      visibility: hidden; /* Takes up space but invisible */
      pointer-events: none;
    }

    /* Canvas is absolute overlay */
    .banner-webgl-canvas {
      position: absolute !important;
      inset: 0;
      width: 100% !important; 
      height: 100% !important;
      z-index: 10;
    }
  </style>
</html>
