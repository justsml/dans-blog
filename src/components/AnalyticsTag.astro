<script>
  if (!isLocalhost(globalThis.location.hostname)) deferAnalytics(initStats);

  async function initStats() {
    const { posthog } = await import("posthog-js/dist/module.js");

    posthog.init(
      "phc_JODNIixGF47WMcySFGQwT2YS7z6ZD5uqk7Tj3KmAqP9",
      {
        api_host: "https://us.i.posthog.com",
        person_profiles: "always",
        disable_session_recording: true,
        capture_pageview: true,
      },
    );

    (globalThis as typeof globalThis & { _posthog?: typeof posthog })._posthog = posthog;
  }

  function deferAnalytics(work: () => void | Promise<void>) {
    let hasRun = false;
    let fallbackTimer: ReturnType<typeof globalThis.setTimeout> | undefined;

    const runOnce = () => {
      if (hasRun) return;
      hasRun = true;
      if (fallbackTimer) globalThis.clearTimeout(fallbackTimer);
      removeInteractionListeners();
      void work();
    };

    const addInteractionListeners = () => {
      for (const eventName of ["pointerdown", "keydown", "scroll", "touchstart"]) {
        window.addEventListener(eventName, runOnce, { once: true, passive: true });
      }
    };

    const removeInteractionListeners = () => {
      for (const eventName of ["pointerdown", "keydown", "scroll", "touchstart"]) {
        window.removeEventListener(eventName, runOnce);
      }
    };

    addInteractionListeners();
    fallbackTimer = globalThis.setTimeout(runOnce, 8000);

    if ("requestIdleCallback" in window) {
      window.requestIdleCallback(runOnce, { timeout: 5000 });
      return;
    }
  }

  // from `local-hostname`
  function isLocalhost(hostname: string) {
    const RGX = /^(::1?|(.*\.)?localhost|((0|10|127)(\.(\d|[1-8]\d|9\d|1\d{2}|2[0-4]\d|25[0-5])){3})|((192\.168|169\.254|(172\.(1[6-9]|2\d|3[01])))(\.(\d|[1-8]\d|9\d|1\d{2}|2[0-4]\d|25[0-5])){2}))$/i;
    return RGX.test(hostname);
  }
</script>
