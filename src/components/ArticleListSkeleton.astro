---
import { pageSize } from "../shared/pagination";

type Props = {
  nextUrl?: string | null;
  pages?: number;
};

const { nextUrl, pages = 3 } = Astro.props as Props;
const skeletonCount = Math.max(pageSize, pageSize * pages);
---

{
  nextUrl && (
    <div
      class="article-list-loader"
      hx-get={nextUrl}
      hx-trigger="revealed"
      hx-swap="outerHTML"
      role="status"
      aria-label="Loading more posts"
    >
      <div class="article-list-loader__grid" aria-hidden="true">
        {Array.from({ length: skeletonCount }).map((_, index) => (
          <div class="article-card-skeleton" style={`--skeleton-index: ${index % pageSize}`}>
            <span class="article-card-skeleton__label"></span>
            <span class="article-card-skeleton__title"></span>
            <span class="article-card-skeleton__summary"></span>
            <span class="article-card-skeleton__media"></span>
            <span class="article-card-skeleton__meta"></span>
          </div>
        ))}
      </div>
    </div>
  )
}
