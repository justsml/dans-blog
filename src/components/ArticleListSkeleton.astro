---
type Props = {
  nextUrl?: string | null;
};

const { nextUrl } = Astro.props as Props;
---

{
  nextUrl && (
    <div
      class="article-list-loader"
      hx-get={nextUrl}
      hx-trigger="revealed"
      hx-swap="outerHTML"
      role="status"
      aria-label="Loading more posts"
    >
      <span class="article-list-loader__indicator" aria-hidden="true"></span>
    </div>
  )
}
