---
import { SITE_TITLE } from "../consts";
import AnimatedLogoType from "./AnimatedLogoType.astro";
import StaticNavMenu from "./StaticNavMenu.astro";
import avatarImage from "@/assets/avatar-88.webp";
import { PostCollections } from "@/shared/postsCache";
import SearchBar from "@/components/SearchUI/SearchBar.astro";
import type { ArticlePost } from "../types";
import {
  ACTIVE_LOCALES,
  DEFAULT_LOCALE,
  getPageLanguageOptions,
  type LanguageOption,
  type Locale,
} from "../shared/i18n";
import { getUiCopy } from "../shared/uiTranslations";

import "./Header.css";

type Props = {
  className?: string;
  date?: string;
  modified?: string;
  locale?: Locale;
  languageOptions?: LanguageOption[];
};

const { className, locale = DEFAULT_LOCALE } = Astro.props as Props;
const languageOptions =
  Astro.props.languageOptions ?? getPageLanguageOptions(Astro.url.pathname, locale);
const languagePreferenceConfig = JSON.stringify({
  currentLocale: locale,
  defaultLocale: DEFAULT_LOCALE,
  locales: [DEFAULT_LOCALE, ...ACTIVE_LOCALES],
});
const copy = getUiCopy(locale);
const currentLanguage =
  languageOptions.find((option) => option.isCurrent) ?? languageOptions[0];
const currentLanguageCode = currentLanguage?.locale.toUpperCase();
const { getCategoryCounts, getPopularPosts, getRecentPosts } = PostCollections;
const categories = getCategoryCounts().slice(0, 6);
const popularPosts = (getPopularPosts() as MyPost[]).map(getNavPostData);
const recentPosts = (getRecentPosts() as MyPost[]).map(getNavPostData);
// const tagCounts = getTagCounts();
// console.log("popularPosts", popularPosts[0]);

type Post<TData extends Record<string, any> = any> = {
  id: string;
  slug: string;
  collection: string;
  body: string;
  data: TData;
};
type MyPost = Post<ArticlePost["data"]>;

function getNavPostData(post: MyPost) {
  const { title, subTitle, modified, date } = post.data;
  return {
    slug: post.slug,
    data: {
      title,
      subTitle,
      modified,
      date,
    },
  };
}
---

<header class:list={["top-header", "default-links", className]}>
  <div class:list={["header-nav", "h-card"]}>
    <h2>
      <AnimatedLogoType
        avatarSrc={avatarImage.src}
        siteTitle={SITE_TITLE}
      />
    </h2>
    <div class="nav-box screenshot-hidden">
      <StaticNavMenu
        categories={categories}
        popularPosts={popularPosts}
        recentPosts={recentPosts}
        locale={locale}
      />
      {
        languageOptions.length > 0 && currentLanguage && (
          <details class="header-language-menu">
            <summary
              class="header-language-trigger"
              aria-label={`${copy.nav.languageLabel}: ${currentLanguage.label}`}
            >
              <span class="header-language-current">{currentLanguageCode}</span>
              <span class="CaretDown" aria-hidden="true">⌄</span>
            </summary>
            <nav class="header-language-panel" aria-label={copy.nav.languageLabel}>
              {languageOptions.map((option) => (
                <a
                  href={option.href}
                  aria-current={option.isCurrent ? "page" : undefined}
                  data-language-locale={option.locale}
                  data-missing={!option.isTranslated ? "true" : undefined}
                  title={
                    option.isTranslated
                      ? `${option.label} ${copy.nav.languageVersion}`
                      : `${option.label} ${copy.nav.languageUnavailable}`
                  }
                >
                  <span class="header-language-name">{option.label}</span>
                  <span class="header-language-code">{option.locale}</span>
                  {
                    !option.isTranslated && (
                      <span class="header-language-status">{copy.nav.languageUnavailable}</span>
                    )
                  }
                </a>
              ))}
            </nav>
          </details>
        )
      }
    </div>
  </div>
</header>

<SearchBar showImages={true} />

<script
  is:inline
  set:html={`
    (() => {
      const KEY = "danlevy:preferred-locale";
      const config = ${languagePreferenceConfig};
      const supportedLocales = new Set(config.locales);

      const readPreferredLocale = () => {
        try {
          const stored = window.localStorage.getItem(KEY);
          return supportedLocales.has(stored) ? stored : null;
        } catch {
          return null;
        }
      };

      const writePreferredLocale = (nextLocale) => {
        if (!supportedLocales.has(nextLocale)) return;
        try {
          window.localStorage.setItem(KEY, nextLocale);
        } catch {
          // Private browsing and locked-down browsers can reject storage.
        }
      };

      const menu = document.querySelector(".header-language-menu");

      menu?.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;
        const link = target.closest("a[data-language-locale]");
        if (!(link instanceof HTMLAnchorElement)) return;
        writePreferredLocale(link.dataset.languageLocale);
      });

      if (config.currentLocale !== config.defaultLocale) {
        writePreferredLocale(config.currentLocale);
      }

      const preferredLocale = readPreferredLocale();
      if (
        !preferredLocale ||
        preferredLocale === config.defaultLocale ||
        config.currentLocale !== config.defaultLocale
      ) {
        return;
      }

      const preferredOption = menu?.querySelector(
        \`a[data-language-locale="\${preferredLocale}"]:not([data-missing="true"])\`,
      );
      if (!(preferredOption instanceof HTMLAnchorElement)) return;

      const preferredUrl = new URL(preferredOption.href, window.location.href);
      if (
        preferredUrl.origin === window.location.origin &&
        preferredUrl.pathname !== window.location.pathname
      ) {
        window.location.replace(preferredUrl.href);
      }
    })();
  `}
/>
